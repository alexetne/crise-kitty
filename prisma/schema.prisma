generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  suspended
  invited

  @@map("user_status")
}

enum AuthProvider {
  local
  google
  microsoft
  sso

  @@map("auth_provider")
}

enum MfaMethodType {
  totp_app
  email

  @@map("mfa_method_type")
}

enum MfaMethodStatus {
  pending
  active
  disabled

  @@map("mfa_method_status")
}

enum MfaChallengeStatus {
  pending
  verified
  expired
  cancelled

  @@map("mfa_challenge_status")
}

model User {
  id              String         @id @db.Uuid
  email           String         @unique @db.VarChar(255)
  firstName       String         @map("first_name") @db.VarChar(100)
  lastName        String         @map("last_name") @db.VarChar(100)
  displayName     String?        @map("display_name") @db.VarChar(150)
  phone           String?        @db.VarChar(30)
  avatarUrl       String?        @map("avatar_url")
  status          UserStatus     @default(active)
  emailVerifiedAt DateTime?      @map("email_verified_at") @db.Timestamptz(6)
  lastLoginAt     DateTime?      @map("last_login_at") @db.Timestamptz(6)
  lastSeenAt      DateTime?      @map("last_seen_at") @db.Timestamptz(6)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?      @map("deleted_at") @db.Timestamptz(6)
  identities      UserIdentity[]
  sessions        UserSession[]
  mfaMethods      UserMfaMethod[]
  mfaChallenges   AuthMfaChallenge[]
  uiSessions      SimulationUiSession[]

  @@map("users")
}

model UserIdentity {
  id             String       @id @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  provider       AuthProvider
  providerUserId String?      @map("provider_user_id") @db.VarChar(255)
  passwordHash   String?      @map("password_hash")
  isPrimary      Boolean      @default(false) @map("is_primary")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  user           User         @relation(fields: [userId], references: [id])
  sessions       UserSession[]

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
  @@map("user_identities")
}

model UserSession {
  id                    String        @id @db.Uuid
  userId                String        @map("user_id") @db.Uuid
  userIdentityId        String?       @map("user_identity_id") @db.Uuid
  refreshTokenHash      String        @map("refresh_token_hash")
  deviceId              String?       @map("device_id") @db.VarChar(120)
  ipAddress             String?       @map("ip_address") @db.Inet
  userAgent             String?
  expiresAt             DateTime      @map("expires_at") @db.Timestamptz(6)
  revokedAt             DateTime?     @map("revoked_at") @db.Timestamptz(6)
  lastUsedAt            DateTime?     @map("last_used_at") @db.Timestamptz(6)
  concurrencyDetectedAt DateTime?     @map("concurrency_detected_at") @db.Timestamptz(6)
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  user                  User          @relation(fields: [userId], references: [id])
  userIdentity          UserIdentity? @relation(fields: [userIdentityId], references: [id])

  @@map("user_sessions")
}

model UserMfaMethod {
  id            String          @id @db.Uuid
  userId        String          @map("user_id") @db.Uuid
  methodType    MfaMethodType   @map("method_type")
  status        MfaMethodStatus @default(pending)
  label         String?         @db.VarChar(100)
  email         String?         @db.VarChar(255)
  secret        String?
  codeHash      String?         @map("code_hash")
  codeExpiresAt DateTime?       @map("code_expires_at") @db.Timestamptz(6)
  lastUsedAt    DateTime?       @map("last_used_at") @db.Timestamptz(6)
  isPrimary     Boolean         @default(false) @map("is_primary")
  verifiedAt    DateTime?       @map("verified_at") @db.Timestamptz(6)
  disabledAt    DateTime?       @map("disabled_at") @db.Timestamptz(6)
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  user          User            @relation(fields: [userId], references: [id])
  challenges    AuthMfaChallenge[]

  @@unique([userId, methodType, label])
  @@map("user_mfa_methods")
}

model AuthMfaChallenge {
  id                String             @id @db.Uuid
  userId            String             @map("user_id") @db.Uuid
  mfaMethodId       String             @map("mfa_method_id") @db.Uuid
  challengeCodeHash String?            @map("challenge_code_hash")
  status            MfaChallengeStatus @default(pending)
  expiresAt         DateTime           @map("expires_at") @db.Timestamptz(6)
  verifiedAt        DateTime?          @map("verified_at") @db.Timestamptz(6)
  cancelledAt       DateTime?          @map("cancelled_at") @db.Timestamptz(6)
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  user              User               @relation(fields: [userId], references: [id])
  mfaMethod         UserMfaMethod      @relation(fields: [mfaMethodId], references: [id])

  @@map("auth_mfa_challenges")
}

model SimulationUiSession {
  id                String   @id @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  sessionKey        String   @map("session_key") @db.VarChar(100)
  routePath         String   @map("route_path") @db.VarChar(255)
  state             Json
  version           Int      @default(1)
  lastClientSavedAt DateTime? @map("last_client_saved_at") @db.Timestamptz(6)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user              User     @relation(fields: [userId], references: [id])

  @@unique([userId, sessionKey])
  @@map("simulation_ui_sessions")
}
