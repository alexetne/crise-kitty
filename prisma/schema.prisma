generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  suspended
  invited

  @@map("user_status")
}

enum AuthProvider {
  local
  google
  microsoft
  sso

  @@map("auth_provider")
}

enum MfaMethodType {
  totp_app
  email

  @@map("mfa_method_type")
}

enum MfaMethodStatus {
  pending
  active
  disabled

  @@map("mfa_method_status")
}

enum MfaChallengeStatus {
  pending
  verified
  expired
  cancelled

  @@map("mfa_challenge_status")
}

enum RoleScope {
  global
  organization

  @@map("role_scope")
}

enum RoleDomain {
  platform
  simulation

  @@map("role_domain")
}

model User {
  id              String         @id @db.Uuid
  email           String         @unique @db.VarChar(255)
  firstName       String         @map("first_name") @db.VarChar(100)
  lastName        String         @map("last_name") @db.VarChar(100)
  displayName     String?        @map("display_name") @db.VarChar(150)
  phone           String?        @db.VarChar(30)
  avatarUrl       String?        @map("avatar_url")
  status          UserStatus     @default(active)
  emailVerifiedAt DateTime?      @map("email_verified_at") @db.Timestamptz(6)
  lastLoginAt     DateTime?      @map("last_login_at") @db.Timestamptz(6)
  lastSeenAt      DateTime?      @map("last_seen_at") @db.Timestamptz(6)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?      @map("deleted_at") @db.Timestamptz(6)
  identities      UserIdentity[]
  organizationMembers OrganizationMember[]
  sessions        UserSession[]
  mfaMethods      UserMfaMethod[]
  mfaChallenges   AuthMfaChallenge[]
  uiSessions      SimulationUiSession[]
  createdScenarios Scenario[]    @relation("ScenarioCreatedByUser")
  updatedScenarios Scenario[]    @relation("ScenarioUpdatedByUser")
  auditLogsForUser UserAuditLog[] @relation("AuditLogUser")
  auditLogsAsActor UserAuditLog[] @relation("AuditLogActor")
  globalRoles     UserGlobalRole[]
  assignedGlobalRoles UserGlobalRole[] @relation("AssignedByUser")
  assignedOrgRoles OrganizationMemberRole[] @relation("AssignedByUser")

  @@map("users")
}

model Organization {
  id                    String               @id @db.Uuid
  name                  String               @db.VarChar(150)
  slug                  String               @unique @db.VarChar(150)
  description           String?
  isActive              Boolean              @default(true) @map("is_active")
  sessionTimeoutMinutes Int                  @default(30) @map("session_timeout_minutes")
  parentOrganizationId  String?              @map("parent_organization_id") @db.Uuid
  logoUrl               String?              @map("logo_url")
  brandName             String?              @map("brand_name") @db.VarChar(150)
  brandPrimaryColor     String?              @map("brand_primary_color") @db.VarChar(20)
  brandSecondaryColor   String?              @map("brand_secondary_color") @db.VarChar(20)
  brandAccentColor      String?              @map("brand_accent_color") @db.VarChar(20)
  createdAt             DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt             DateTime?            @map("deleted_at") @db.Timestamptz(6)
  parentOrganization    Organization?        @relation("OrganizationHierarchy", fields: [parentOrganizationId], references: [id])
  childOrganizations    Organization[]       @relation("OrganizationHierarchy")
  members               OrganizationMember[]
  activeSessions        UserSession[]        @relation("ActiveOrganizationSession")
  scenarios             Scenario[]
  auditLogs             UserAuditLog[]

  @@map("organizations")
}

model OrganizationMember {
  id             String       @id @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  jobTitle       String?      @map("job_title") @db.VarChar(100)
  department     String?      @db.VarChar(100)
  status         String       @db.VarChar(20)
  joinedAt       DateTime     @default(now()) @map("joined_at") @db.Timestamptz(6)
  leftAt         DateTime?    @map("left_at") @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?    @map("deleted_at") @db.Timestamptz(6)
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
  roles          OrganizationMemberRole[]

  @@unique([organizationId, userId])
  @@map("organization_members")
}

model UserIdentity {
  id             String       @id @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  provider       AuthProvider
  providerUserId String?      @map("provider_user_id") @db.VarChar(255)
  passwordHash   String?      @map("password_hash")
  isPrimary      Boolean      @default(false) @map("is_primary")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  user           User         @relation(fields: [userId], references: [id])
  sessions       UserSession[]

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
  @@map("user_identities")
}

model UserSession {
  id                    String        @id @db.Uuid
  userId                String        @map("user_id") @db.Uuid
  userIdentityId        String?       @map("user_identity_id") @db.Uuid
  activeOrganizationId  String?       @map("active_organization_id") @db.Uuid
  refreshTokenHash      String        @map("refresh_token_hash")
  deviceId              String?       @map("device_id") @db.VarChar(120)
  ipAddress             String?       @map("ip_address") @db.Inet
  userAgent             String?       @map("user_agent")
  expiresAt             DateTime      @map("expires_at") @db.Timestamptz(6)
  revokedAt             DateTime?     @map("revoked_at") @db.Timestamptz(6)
  lastUsedAt            DateTime?     @map("last_used_at") @db.Timestamptz(6)
  concurrencyDetectedAt DateTime?     @map("concurrency_detected_at") @db.Timestamptz(6)
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  user                  User          @relation(fields: [userId], references: [id])
  userIdentity          UserIdentity? @relation(fields: [userIdentityId], references: [id])
  activeOrganization    Organization? @relation("ActiveOrganizationSession", fields: [activeOrganizationId], references: [id])

  @@map("user_sessions")
}

model UserMfaMethod {
  id            String          @id @db.Uuid
  userId        String          @map("user_id") @db.Uuid
  methodType    MfaMethodType   @map("method_type")
  status        MfaMethodStatus @default(pending)
  label         String?         @db.VarChar(100)
  email         String?         @db.VarChar(255)
  secret        String?
  codeHash      String?         @map("code_hash")
  codeExpiresAt DateTime?       @map("code_expires_at") @db.Timestamptz(6)
  lastUsedAt    DateTime?       @map("last_used_at") @db.Timestamptz(6)
  isPrimary     Boolean         @default(false) @map("is_primary")
  verifiedAt    DateTime?       @map("verified_at") @db.Timestamptz(6)
  disabledAt    DateTime?       @map("disabled_at") @db.Timestamptz(6)
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  user          User            @relation(fields: [userId], references: [id])
  challenges    AuthMfaChallenge[]

  @@unique([userId, methodType, label])
  @@map("user_mfa_methods")
}

model AuthMfaChallenge {
  id                String             @id @db.Uuid
  userId            String             @map("user_id") @db.Uuid
  mfaMethodId       String             @map("mfa_method_id") @db.Uuid
  challengeCodeHash String?            @map("challenge_code_hash")
  status            MfaChallengeStatus @default(pending)
  expiresAt         DateTime           @map("expires_at") @db.Timestamptz(6)
  verifiedAt        DateTime?          @map("verified_at") @db.Timestamptz(6)
  cancelledAt       DateTime?          @map("cancelled_at") @db.Timestamptz(6)
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  user              User               @relation(fields: [userId], references: [id])
  mfaMethod         UserMfaMethod      @relation(fields: [mfaMethodId], references: [id])

  @@map("auth_mfa_challenges")
}

model SimulationUiSession {
  id                String   @id @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  sessionKey        String   @map("session_key") @db.VarChar(100)
  routePath         String   @map("route_path") @db.VarChar(255)
  state             Json
  version           Int      @default(1)
  lastClientSavedAt DateTime? @map("last_client_saved_at") @db.Timestamptz(6)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user              User     @relation(fields: [userId], references: [id])

  @@unique([userId, sessionKey])
  @@map("simulation_ui_sessions")
}

model Scenario {
  id                  String        @id @db.Uuid
  organizationId      String?       @map("organization_id") @db.Uuid
  crisisDomainId      String        @map("crisis_domain_id") @db.Uuid
  crisisTypeId        String?       @map("crisis_type_id") @db.Uuid
  crisisSubtypeId     String?       @map("crisis_subtype_id") @db.Uuid
  code                String        @unique @db.VarChar(50)
  title               String        @db.VarChar(200)
  summary             String?
  businessCategory    String?       @map("business_category") @db.VarChar(100)
  status              String        @db.VarChar(20)
  visibility          String        @db.VarChar(20)
  mode                String        @db.VarChar(20)
  defaultDifficulty   String        @map("default_difficulty") @db.VarChar(20)
  minDurationMinutes  Int?          @map("min_duration_minutes")
  maxDurationMinutes  Int?          @map("max_duration_minutes")
  recommendedDurationMinutes Int?   @map("recommended_duration_minutes")
  minParticipants     Int?          @map("min_participants")
  maxParticipants     Int?          @map("max_participants")
  currentVersionId    String?       @map("current_version_id") @db.Uuid
  createdByUserId     String?       @map("created_by_user_id") @db.Uuid
  updatedByUserId     String?       @map("updated_by_user_id") @db.Uuid
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  archivedAt          DateTime?     @map("archived_at") @db.Timestamptz(6)
  organization        Organization? @relation(fields: [organizationId], references: [id])
  createdByUser       User?         @relation("ScenarioCreatedByUser", fields: [createdByUserId], references: [id])
  updatedByUser       User?         @relation("ScenarioUpdatedByUser", fields: [updatedByUserId], references: [id])

  @@map("scenarios")
}

model UserAuditLog {
  id             BigInt        @id @default(autoincrement())
  userId         String?       @map("user_id") @db.Uuid
  actorUserId    String?       @map("actor_user_id") @db.Uuid
  organizationId String?       @map("organization_id") @db.Uuid
  eventType      String        @map("event_type") @db.VarChar(100)
  eventData      Json?         @map("event_data")
  ipAddress      String?       @map("ip_address") @db.Inet
  userAgent      String?       @map("user_agent")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  user           User?         @relation("AuditLogUser", fields: [userId], references: [id])
  actorUser      User?         @relation("AuditLogActor", fields: [actorUserId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@map("user_audit_logs")
}

model Role {
  id          String         @id @db.Uuid
  code        String         @unique @db.VarChar(50)
  name        String         @db.VarChar(100)
  scope       RoleScope
  domain      RoleDomain     @default(simulation)
  description String?
  isSystem    Boolean        @default(false) @map("is_system")
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  permissions RolePermission[]
  globalUsers UserGlobalRole[]
  orgMembers  OrganizationMemberRole[]

  @@map("roles")
}

model Permission {
  id          String         @id @db.Uuid
  code        String         @unique @db.VarChar(100)
  name        String         @db.VarChar(150)
  description String?
  resource    String         @db.VarChar(100)
  action      String         @db.VarChar(50)
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  roles       RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  role         Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserGlobalRole {
  id               String   @id @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  roleId           String   @map("role_id") @db.Uuid
  assignedByUserId String?  @map("assigned_by_user_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role             Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedByUser   User?    @relation("AssignedByUser", fields: [assignedByUserId], references: [id])

  @@map("user_global_roles")
}

model OrganizationMemberRole {
  id                   String            @id @db.Uuid
  organizationMemberId String            @map("organization_member_id") @db.Uuid
  roleId               String            @map("role_id") @db.Uuid
  assignedByUserId     String?           @map("assigned_by_user_id") @db.Uuid
  createdAt            DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  organizationMember   OrganizationMember @relation(fields: [organizationMemberId], references: [id], onDelete: Cascade)
  role                 Role              @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedByUser       User?             @relation("AssignedByUser", fields: [assignedByUserId], references: [id])

  @@map("organization_member_roles")
}
