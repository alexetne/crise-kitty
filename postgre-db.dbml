Project crisis_simulation_platform {
  database_type: "PostgreSQL"
  Note: '''
  Schéma cible unifié pour une plateforme de simulation de crise.

  Couverture de cette version :
  - IAM plateforme : utilisateurs, authentification, sessions, organisations, RBAC, audit
  - bibliothèque de crises : domaines, types, sous-types, tags
  - coeur éditorial : scénarios, versions, objectifs, variables, ressources, acteurs
  - arbre de décision : noeuds, choix, transitions, conditions, checkpoints, outcomes
  - injects et règles : injects, déclencheurs, effets, règles, conditions, actions
  - runtime : sessions de simulation, participants, variables d'état, événements, choix, conséquences

  Hors périmètre de cette version :
  - dashboard opérationnel, cartographie, messagerie, médias, RH, logistique, budget
  - IA avancée, probative logbook, RETEX, scoring détaillé, conformité
  '''
}

Enum user_status {
  active
  suspended
  disabled
  archived
}

Enum membership_status {
  active
  suspended
  left
}

Enum invitation_status {
  pending
  accepted
  revoked
  expired
}

Enum auth_provider {
  local
  google
  microsoft
  sso
}

Enum token_type {
  password_reset
  email_verification
  magic_login
}

Enum role_scope {
  global
  organization
}

Enum crisis_domain_status {
  active
  inactive
  archived
}

Enum scenario_status {
  draft
  review
  published
  archived
}

Enum scenario_visibility {
  private
  organization
  public_catalog
}

Enum scenario_mode {
  scripted
  hybrid
  ai
}

Enum difficulty_level {
  very_easy
  easy
  medium
  hard
  expert
  custom
}

Enum scenario_variable_type {
  integer
  decimal
  boolean
  text
  json
}

Enum resource_type {
  document
  image
  video
  audio
  link
  file
  template
}

Enum actor_role_type {
  facilitator
  participant
  observer
  npc
  authority
  media
  stakeholder
}

Enum node_type {
  start
  narrative
  decision
  incident
  consequence
  checkpoint
  end_success
  end_failure
  end_neutral
}

Enum choice_type {
  single
  multiple
  hidden
  timed
  automatic
}

Enum transition_type {
  manual
  automatic
  conditional
  scheduled
}

Enum condition_operator {
  eq
  neq
  gt
  gte
  lt
  lte
  in
  not_in
  contains
  not_contains
  is_true
  is_false
  changed
}

Enum inject_type {
  email
  call
  media
  alert
  message
  social_post
  authority_notice
  document
  custom
}

Enum inject_channel {
  email
  phone
  dashboard
  chat
  press
  social_network
  siren
  official_letter
  custom
}

Enum inject_priority {
  low
  medium
  high
  critical
}

Enum trigger_type {
  manual
  automatic
  scheduled
  conditional
}

Enum trigger_source {
  timeline
  player_choice
  facilitator_action
  rule_engine
  system
}

Enum rule_action_type {
  set_variable
  increment_variable
  decrement_variable
  activate_edge
  deactivate_edge
  unlock_choice
  lock_choice
  trigger_inject
  set_node
  set_status
  add_tag
  remove_tag
  end_scenario
}

Enum session_status {
  planned
  running
  paused
  completed
  cancelled
  archived
}

Enum session_participant_role {
  facilitator
  participant
  observer
  evaluator
}

Enum session_event_type {
  session_started
  session_paused
  session_resumed
  session_ended
  node_entered
  choice_made
  inject_triggered
  rule_triggered
  variable_changed
  consequence_applied
  checkpoint_reached
  note_added
}

Table users {
  id uuid [pk, not null]
  email varchar(255) [not null, unique]
  first_name varchar(100) [not null]
  last_name varchar(100) [not null]
  display_name varchar(150)
  phone varchar(30)
  avatar_url text

  status user_status [not null, default: 'active']
  email_verified_at timestamptz
  last_login_at timestamptz
  last_seen_at timestamptz

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz

  indexes {
    email
    status
    last_login_at
  }
}

Table user_identities {
  id uuid [pk, not null]
  user_id uuid [not null, ref: > users.id]
  provider auth_provider [not null]
  provider_user_id varchar(255)
  password_hash text
  is_primary boolean [not null, default: false]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    user_id
    (provider, provider_user_id) [unique]
    (user_id, provider) [unique]
  }

  Note: '''
  Une identité par fournisseur d'authentification.
  password_hash n'est utilisé que pour provider = local.
  '''
}

Table organizations {
  id uuid [pk, not null]
  name varchar(150) [not null]
  slug varchar(150) [not null, unique]
  description text
  is_active boolean [not null, default: true]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz

  indexes {
    slug
    is_active
  }
}

Table organization_members {
  id uuid [pk, not null]
  organization_id uuid [not null, ref: > organizations.id]
  user_id uuid [not null, ref: > users.id]

  job_title varchar(100)
  department varchar(100)
  status membership_status [not null, default: 'active']
  joined_at timestamptz [not null, default: `now()`]
  left_at timestamptz

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz

  indexes {
    (organization_id, user_id) [unique]
    organization_id
    user_id
    status
  }
}

Table organization_invitations {
  id uuid [pk, not null]
  organization_id uuid [not null, ref: > organizations.id]
  email varchar(255) [not null]
  invited_user_id uuid [ref: > users.id]
  invited_by_user_id uuid [not null, ref: > users.id]

  status invitation_status [not null, default: 'pending']
  expires_at timestamptz [not null]
  accepted_at timestamptz
  revoked_at timestamptz

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    organization_id
    email
    status
    expires_at
  }
}

Table roles {
  id uuid [pk, not null]
  code varchar(50) [not null, unique]
  name varchar(100) [not null]
  scope role_scope [not null]
  description text
  is_system boolean [not null, default: false]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    code
    scope
  }
}

Table permissions {
  id uuid [pk, not null]
  code varchar(100) [not null, unique]
  name varchar(150) [not null]
  description text
  resource varchar(100) [not null]
  action varchar(50) [not null]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    code
    (resource, action) [unique]
  }
}

Table role_permissions {
  role_id uuid [not null, ref: > roles.id]
  permission_id uuid [not null, ref: > permissions.id]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (role_id, permission_id) [pk]
    permission_id
  }
}

Table user_global_roles {
  id uuid [pk, not null]
  user_id uuid [not null, ref: > users.id]
  role_id uuid [not null, ref: > roles.id]
  assigned_by_user_id uuid [ref: > users.id]

  created_at timestamptz [not null, default: `now()`]

  indexes {
    (user_id, role_id) [unique]
    user_id
    role_id
  }
}

Table organization_member_roles {
  id uuid [pk, not null]
  organization_member_id uuid [not null, ref: > organization_members.id]
  role_id uuid [not null, ref: > roles.id]
  assigned_by_user_id uuid [ref: > users.id]

  created_at timestamptz [not null, default: `now()`]

  indexes {
    (organization_member_id, role_id) [unique]
    organization_member_id
    role_id
  }
}

Table user_sessions {
  id uuid [pk, not null]
  user_id uuid [not null, ref: > users.id]
  user_identity_id uuid [ref: > user_identities.id]

  refresh_token_hash text [not null]
  ip_address inet
  user_agent text
  expires_at timestamptz [not null]
  revoked_at timestamptz
  last_used_at timestamptz

  created_at timestamptz [not null, default: `now()`]

  indexes {
    user_id
    user_identity_id
    expires_at
  }
}

Table auth_tokens {
  id uuid [pk, not null]
  user_id uuid [not null, ref: > users.id]
  user_identity_id uuid [ref: > user_identities.id]

  token_hash text [not null]
  token_type token_type [not null]
  expires_at timestamptz [not null]
  used_at timestamptz

  created_at timestamptz [not null, default: `now()`]

  indexes {
    user_id
    user_identity_id
    token_type
    expires_at
  }
}

Table user_audit_logs {
  id bigserial [pk, not null]
  user_id uuid [ref: > users.id]
  actor_user_id uuid [ref: > users.id]
  organization_id uuid [ref: > organizations.id]

  event_type varchar(100) [not null]
  event_data jsonb
  ip_address inet
  user_agent text

  created_at timestamptz [not null, default: `now()`]

  indexes {
    user_id
    actor_user_id
    organization_id
    event_type
    created_at
  }
}

Table crisis_domains {
  id uuid [pk, not null]
  code varchar(50) [not null, unique]
  name varchar(150) [not null]
  description text
  status crisis_domain_status [not null, default: 'active']
  default_severity smallint [not null, default: 1]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    code
    status
  }
}

Table crisis_types {
  id uuid [pk, not null]
  crisis_domain_id uuid [not null, ref: > crisis_domains.id]
  code varchar(50) [not null]
  name varchar(150) [not null]
  description text
  default_severity smallint [not null, default: 1]
  is_active boolean [not null, default: true]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    crisis_domain_id
    (crisis_domain_id, code) [unique]
    is_active
  }
}

Table crisis_subtypes {
  id uuid [pk, not null]
  crisis_type_id uuid [not null, ref: > crisis_types.id]
  code varchar(50) [not null]
  name varchar(150) [not null]
  description text
  default_severity smallint [not null, default: 1]
  is_active boolean [not null, default: true]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    crisis_type_id
    (crisis_type_id, code) [unique]
    is_active
  }
}

Table classification_tags {
  id uuid [pk, not null]
  code varchar(50) [not null, unique]
  label varchar(100) [not null]
  category varchar(100)
  description text
  color varchar(20)
  is_active boolean [not null, default: true]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    code
    category
    is_active
  }
}

Table scenarios {
  id uuid [pk, not null]
  organization_id uuid [ref: > organizations.id]
  crisis_domain_id uuid [not null, ref: > crisis_domains.id]
  crisis_type_id uuid [ref: > crisis_types.id]
  crisis_subtype_id uuid [ref: > crisis_subtypes.id]

  code varchar(50) [not null, unique]
  title varchar(200) [not null]
  summary text
  business_category varchar(100)

  status scenario_status [not null, default: 'draft']
  visibility scenario_visibility [not null, default: 'private']
  mode scenario_mode [not null, default: 'scripted']
  default_difficulty difficulty_level [not null, default: 'medium']

  min_duration_minutes int
  max_duration_minutes int
  recommended_duration_minutes int

  min_participants int
  max_participants int

  current_version_id uuid
  created_by_user_id uuid [ref: > users.id]
  updated_by_user_id uuid [ref: > users.id]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  archived_at timestamptz

  indexes {
    code
    organization_id
    crisis_domain_id
    status
    visibility
    mode
  }
}

Table scenario_versions {
  id uuid [pk, not null]
  scenario_id uuid [not null, ref: > scenarios.id]
  version_number int [not null]
  label varchar(100)

  status scenario_status [not null, default: 'draft']
  is_published boolean [not null, default: false]
  is_archived boolean [not null, default: false]

  content_summary text
  facilitator_notes text
  balancing_profile varchar(100)

  created_by_user_id uuid [ref: > users.id]
  published_by_user_id uuid [ref: > users.id]
  published_at timestamptz

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_id
    (scenario_id, version_number) [unique]
    status
    is_published
  }
}

Table scenario_tag_links {
  scenario_id uuid [not null, ref: > scenarios.id]
  tag_id uuid [not null, ref: > classification_tags.id]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (scenario_id, tag_id) [pk]
    tag_id
  }
}

Table scenario_learning_objectives {
  id uuid [pk, not null]
  scenario_version_id uuid [not null, ref: > scenario_versions.id]
  title varchar(200) [not null]
  description text
  sort_order int [not null, default: 0]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_version_id
    sort_order
  }
}

Table scenario_difficulty_profiles {
  id uuid [pk, not null]
  scenario_version_id uuid [not null, ref: > scenario_versions.id]
  code varchar(50) [not null]
  label varchar(100) [not null]
  difficulty difficulty_level [not null]
  description text
  settings jsonb

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_version_id
    (scenario_version_id, code) [unique]
  }
}

Table scenario_duration_profiles {
  id uuid [pk, not null]
  scenario_version_id uuid [not null, ref: > scenario_versions.id]
  code varchar(50) [not null]
  label varchar(100) [not null]
  duration_minutes int [not null]
  description text
  settings jsonb

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_version_id
    (scenario_version_id, code) [unique]
  }
}

Table scenario_balancing_profiles {
  id uuid [pk, not null]
  scenario_version_id uuid [not null, ref: > scenario_versions.id]
  code varchar(50) [not null]
  label varchar(100) [not null]
  description text
  settings jsonb

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_version_id
    (scenario_version_id, code) [unique]
  }
}

Table scenario_variables {
  id uuid [pk, not null]
  scenario_version_id uuid [not null, ref: > scenario_versions.id]
  code varchar(100) [not null]
  name varchar(150) [not null]
  variable_type scenario_variable_type [not null]

  default_value jsonb
  min_value numeric(14,4)
  max_value numeric(14,4)
  visibility varchar(30) [not null, default: 'facilitator']
  is_runtime boolean [not null, default: true]
  is_ai_managed boolean [not null, default: false]
  description text

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_version_id
    (scenario_version_id, code) [unique]
    visibility
  }
}

Table scenario_resources {
  id uuid [pk, not null]
  scenario_version_id uuid [not null, ref: > scenario_versions.id]
  code varchar(100) [not null]
  name varchar(150) [not null]
  resource_type resource_type [not null]
  description text
  content text
  file_url text
  metadata jsonb

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_version_id
    (scenario_version_id, code) [unique]
    resource_type
  }
}

Table scenario_actors {
  id uuid [pk, not null]
  scenario_version_id uuid [not null, ref: > scenario_versions.id]
  code varchar(100) [not null]
  name varchar(150) [not null]
  actor_role actor_role_type [not null]
  description text
  persona jsonb
  default_stress_level smallint
  default_influence_level smallint

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_version_id
    (scenario_version_id, code) [unique]
    actor_role
  }
}

Table scenario_structures {
  id uuid [pk, not null]
  scenario_version_id uuid [not null, ref: > scenario_versions.id, unique]
  name varchar(150) [not null]
  description text
  start_node_id uuid

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_version_id
  }
}

Table scenario_nodes {
  id uuid [pk, not null]
  scenario_structure_id uuid [not null, ref: > scenario_structures.id]
  code varchar(100) [not null]
  title varchar(150) [not null]
  node_type node_type [not null]

  narrative_content text
  facilitator_notes text
  incident_severity smallint
  time_limit_seconds int

  is_start boolean [not null, default: false]
  is_active boolean [not null, default: true]
  sort_order int [not null, default: 0]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_structure_id
    (scenario_structure_id, code) [unique]
    node_type
    is_start
    is_active
  }
}

Table node_resources {
  node_id uuid [not null, ref: > scenario_nodes.id]
  resource_id uuid [not null, ref: > scenario_resources.id]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (node_id, resource_id) [pk]
    resource_id
  }
}

Table node_actors {
  node_id uuid [not null, ref: > scenario_nodes.id]
  actor_id uuid [not null, ref: > scenario_actors.id]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (node_id, actor_id) [pk]
    actor_id
  }
}

Table node_choices {
  id uuid [pk, not null]
  node_id uuid [not null, ref: > scenario_nodes.id]
  code varchar(100) [not null]
  label varchar(200) [not null]
  description text
  choice_type choice_type [not null, default: 'single']
  is_default boolean [not null, default: false]
  is_locked boolean [not null, default: false]
  unlock_condition_summary text
  timeout_seconds int
  sort_order int [not null, default: 0]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    node_id
    (node_id, code) [unique]
    choice_type
    sort_order
  }
}

Table node_edges {
  id uuid [pk, not null]
  scenario_structure_id uuid [not null, ref: > scenario_structures.id]
  source_node_id uuid [not null, ref: > scenario_nodes.id]
  target_node_id uuid [not null, ref: > scenario_nodes.id]
  source_choice_id uuid [ref: > node_choices.id]

  code varchar(100) [not null]
  label varchar(150)
  transition_type transition_type [not null, default: 'manual']
  is_enabled boolean [not null, default: true]
  is_hidden boolean [not null, default: false]
  delay_seconds int
  priority smallint [not null, default: 1]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_structure_id
    source_node_id
    target_node_id
    source_choice_id
    (scenario_structure_id, code) [unique]
    is_enabled
  }
}

Table edge_conditions {
  id uuid [pk, not null]
  edge_id uuid [not null, ref: > node_edges.id]
  scenario_variable_id uuid [ref: > scenario_variables.id]
  operator condition_operator [not null]
  expected_value jsonb
  sort_order int [not null, default: 0]

  created_at timestamptz [not null, default: `now()`]

  indexes {
    edge_id
    scenario_variable_id
    sort_order
  }
}

Table scenario_checkpoints {
  id uuid [pk, not null]
  scenario_version_id uuid [not null, ref: > scenario_versions.id]
  node_id uuid [ref: > scenario_nodes.id]
  code varchar(100) [not null]
  name varchar(150) [not null]
  description text
  is_mandatory boolean [not null, default: false]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_version_id
    node_id
    (scenario_version_id, code) [unique]
  }
}

Table checkpoint_conditions {
  id uuid [pk, not null]
  checkpoint_id uuid [not null, ref: > scenario_checkpoints.id]
  scenario_variable_id uuid [ref: > scenario_variables.id]
  operator condition_operator [not null]
  expected_value jsonb
  sort_order int [not null, default: 0]

  created_at timestamptz [not null, default: `now()`]

  indexes {
    checkpoint_id
    scenario_variable_id
    sort_order
  }
}

Table scenario_outcomes {
  id uuid [pk, not null]
  scenario_version_id uuid [not null, ref: > scenario_versions.id]
  node_id uuid [ref: > scenario_nodes.id]
  code varchar(100) [not null]
  name varchar(150) [not null]
  description text
  outcome_type varchar(50) [not null, default: 'generic']
  success_score numeric(6,2)

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_version_id
    node_id
    (scenario_version_id, code) [unique]
  }
}

Table scenario_injects {
  id uuid [pk, not null]
  scenario_version_id uuid [not null, ref: > scenario_versions.id]
  node_id uuid [ref: > scenario_nodes.id]
  code varchar(100) [not null]
  title varchar(150) [not null]

  inject_type inject_type [not null]
  channel inject_channel [not null]
  priority inject_priority [not null, default: 'medium']

  content_text text
  content_html text
  is_repeatable boolean [not null, default: false]
  valid_from_offset_seconds int
  valid_until_offset_seconds int
  metadata jsonb

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_version_id
    node_id
    (scenario_version_id, code) [unique]
    inject_type
    channel
  }
}

Table inject_resources {
  inject_id uuid [not null, ref: > scenario_injects.id]
  resource_id uuid [not null, ref: > scenario_resources.id]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (inject_id, resource_id) [pk]
    resource_id
  }
}

Table inject_triggers {
  id uuid [pk, not null]
  inject_id uuid [not null, ref: > scenario_injects.id]
  trigger_type trigger_type [not null]
  trigger_source trigger_source [not null]

  offset_seconds int
  cron_expression varchar(100)
  source_node_id uuid [ref: > scenario_nodes.id]
  source_choice_id uuid [ref: > node_choices.id]
  is_active boolean [not null, default: true]
  priority smallint [not null, default: 1]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    inject_id
    trigger_type
    trigger_source
    is_active
  }
}

Table inject_trigger_conditions {
  id uuid [pk, not null]
  inject_trigger_id uuid [not null, ref: > inject_triggers.id]
  scenario_variable_id uuid [ref: > scenario_variables.id]
  operator condition_operator [not null]
  expected_value jsonb
  sort_order int [not null, default: 0]

  created_at timestamptz [not null, default: `now()`]

  indexes {
    inject_trigger_id
    scenario_variable_id
    sort_order
  }
}

Table inject_effects {
  id uuid [pk, not null]
  inject_id uuid [not null, ref: > scenario_injects.id]
  effect_type rule_action_type [not null]
  target_type varchar(50) [not null]
  target_id uuid
  payload jsonb
  sort_order int [not null, default: 0]

  created_at timestamptz [not null, default: `now()`]

  indexes {
    inject_id
    effect_type
    sort_order
  }
}

Table scenario_rules {
  id uuid [pk, not null]
  scenario_version_id uuid [not null, ref: > scenario_versions.id]
  code varchar(100) [not null]
  name varchar(150) [not null]
  description text
  priority smallint [not null, default: 1]
  is_active boolean [not null, default: true]
  is_system boolean [not null, default: false]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_version_id
    (scenario_version_id, code) [unique]
    priority
    is_active
    is_system
  }
}

Table rule_conditions {
  id uuid [pk, not null]
  rule_id uuid [not null, ref: > scenario_rules.id]
  scenario_variable_id uuid [ref: > scenario_variables.id]
  operator condition_operator [not null]
  expected_value jsonb
  sort_order int [not null, default: 0]

  created_at timestamptz [not null, default: `now()`]

  indexes {
    rule_id
    scenario_variable_id
    sort_order
  }
}

Table rule_actions {
  id uuid [pk, not null]
  rule_id uuid [not null, ref: > scenario_rules.id]
  action_type rule_action_type [not null]
  target_type varchar(50) [not null]
  target_id uuid
  payload jsonb
  sort_order int [not null, default: 0]

  created_at timestamptz [not null, default: `now()`]

  indexes {
    rule_id
    action_type
    sort_order
  }
}

Table simulation_sessions {
  id uuid [pk, not null]
  scenario_version_id uuid [not null, ref: > scenario_versions.id]
  organization_id uuid [ref: > organizations.id]

  code varchar(50) [not null, unique]
  title varchar(200) [not null]
  status session_status [not null, default: 'planned']

  selected_difficulty difficulty_level
  duration_profile_code varchar(50)
  balancing_profile_code varchar(50)

  started_at timestamptz
  paused_at timestamptz
  ended_at timestamptz
  current_time_seconds int [not null, default: 0]

  current_node_id uuid [ref: > scenario_nodes.id]
  engine_state jsonb
  random_seed varchar(100)

  created_by_user_id uuid [ref: > users.id]
  facilitator_user_id uuid [ref: > users.id]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    code
    scenario_version_id
    organization_id
    status
    started_at
    ended_at
  }
}

Table simulation_session_participants {
  id uuid [pk, not null]
  simulation_session_id uuid [not null, ref: > simulation_sessions.id]
  user_id uuid [ref: > users.id]
  organization_member_id uuid [ref: > organization_members.id]

  role_in_session session_participant_role [not null, default: 'participant']
  assigned_actor_id uuid [ref: > scenario_actors.id]
  assigned_role_label varchar(100)
  joined_at timestamptz
  left_at timestamptz
  is_active boolean [not null, default: true]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_session_id
    user_id
    organization_member_id
    role_in_session
    is_active
  }
}

Table simulation_state_variables {
  id uuid [pk, not null]
  simulation_session_id uuid [not null, ref: > simulation_sessions.id]
  scenario_variable_id uuid [not null, ref: > scenario_variables.id]

  current_value jsonb
  last_changed_at timestamptz
  last_changed_by_user_id uuid [ref: > users.id]
  last_change_source varchar(50)

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_session_id
    scenario_variable_id
    (simulation_session_id, scenario_variable_id) [unique]
    last_changed_at
  }
}

Table simulation_variable_history {
  id bigserial [pk, not null]
  simulation_state_variable_id uuid [not null, ref: > simulation_state_variables.id]
  old_value jsonb
  new_value jsonb
  change_reason varchar(100)
  changed_by_user_id uuid [ref: > users.id]
  changed_by_rule_id uuid [ref: > scenario_rules.id]
  changed_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_state_variable_id
    changed_by_user_id
    changed_by_rule_id
    changed_at
  }
}

Table simulation_session_events {
  id bigserial [pk, not null]
  simulation_session_id uuid [not null, ref: > simulation_sessions.id]
  event_type session_event_type [not null]
  node_id uuid [ref: > scenario_nodes.id]
  actor_user_id uuid [ref: > users.id]
  participant_id uuid [ref: > simulation_session_participants.id]
  payload jsonb
  occurred_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_session_id
    event_type
    node_id
    occurred_at
  }
}

Table simulation_choice_history {
  id bigserial [pk, not null]
  simulation_session_id uuid [not null, ref: > simulation_sessions.id]
  node_id uuid [not null, ref: > scenario_nodes.id]
  choice_id uuid [not null, ref: > node_choices.id]
  participant_id uuid [ref: > simulation_session_participants.id]
  chosen_at timestamptz [not null, default: `now()`]
  payload jsonb

  indexes {
    simulation_session_id
    node_id
    choice_id
    participant_id
    chosen_at
  }
}

Table simulation_inject_history {
  id bigserial [pk, not null]
  simulation_session_id uuid [not null, ref: > simulation_sessions.id]
  inject_id uuid [not null, ref: > scenario_injects.id]
  trigger_id uuid [ref: > inject_triggers.id]
  triggered_by_user_id uuid [ref: > users.id]
  triggered_at timestamptz [not null, default: `now()`]
  delivery_status varchar(50) [not null, default: 'triggered']
  payload jsonb

  indexes {
    simulation_session_id
    inject_id
    trigger_id
    triggered_at
  }
}

Table simulation_rule_history {
  id bigserial [pk, not null]
  simulation_session_id uuid [not null, ref: > simulation_sessions.id]
  rule_id uuid [not null, ref: > scenario_rules.id]
  triggered_at timestamptz [not null, default: `now()`]
  was_applied boolean [not null, default: true]
  result_payload jsonb

  indexes {
    simulation_session_id
    rule_id
    triggered_at
    was_applied
  }
}

Table simulation_consequence_history {
  id bigserial [pk, not null]
  simulation_session_id uuid [not null, ref: > simulation_sessions.id]
  source_type varchar(50) [not null]
  source_id uuid
  consequence_type rule_action_type [not null]
  target_type varchar(50) [not null]
  target_id uuid
  payload jsonb
  applied_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_session_id
    source_type
    consequence_type
    applied_at
  }
}

Ref: scenarios.current_version_id > scenario_versions.id
Ref: scenario_structures.start_node_id > scenario_nodes.id

TableGroup "Identity" {
  users
  user_identities
  user_sessions
  auth_tokens
}

TableGroup "Organizations" {
  organizations
  organization_members
  organization_invitations
}

TableGroup "Authorization" {
  roles
  permissions
  role_permissions
  user_global_roles
  organization_member_roles
}

TableGroup "Audit" {
  user_audit_logs
}

TableGroup "Crisis Library" {
  crisis_domains
  crisis_types
  crisis_subtypes
  classification_tags
}

TableGroup "Scenario Editorial" {
  scenarios
  scenario_versions
  scenario_tag_links
  scenario_learning_objectives
  scenario_difficulty_profiles
  scenario_duration_profiles
  scenario_balancing_profiles
  scenario_variables
  scenario_resources
  scenario_actors
}

TableGroup "Decision Tree" {
  scenario_structures
  scenario_nodes
  node_resources
  node_actors
  node_choices
  node_edges
  edge_conditions
  scenario_checkpoints
  checkpoint_conditions
  scenario_outcomes
}

TableGroup "Rules And Injects" {
  scenario_injects
  inject_resources
  inject_triggers
  inject_trigger_conditions
  inject_effects
  scenario_rules
  rule_conditions
  rule_actions
}

TableGroup "Simulation Runtime" {
  simulation_sessions
  simulation_session_participants
  simulation_state_variables
  simulation_variable_history
  simulation_session_events
  simulation_choice_history
  simulation_inject_history
  simulation_rule_history
  simulation_consequence_history
}
