Project crisis_simulation_users {
  database_type: "PostgreSQL"
  Note: '''
  Gestion des utilisateurs pour une application de simulation de crise.
  Portée actuelle :
  - utilisateurs
  - organisations
  - rôles
  - appartenance organisationnelle
  - sessions
  - réinitialisation mot de passe
  - audit basique
  '''
}

Enum user_status {
  pending
  active
  suspended
  disabled
  archived
}

Enum membership_status {
  invited
  active
  suspended
  left
}

Enum auth_provider {
  local
  google
  microsoft
  sso
}

Enum token_type {
  password_reset
  email_verification
  magic_login
}

Table organizations {
  id uuid [pk, not null]
  name varchar(150) [not null]
  slug varchar(150) [not null, unique]
  description text
  is_active boolean [not null, default: true]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz

  Note: 'Entité cliente ou structure utilisant la plateforme'
}

Table users {
  id uuid [pk, not null]
  email varchar(255) [not null, unique]
  username varchar(50) [not null, unique]
  password_hash text
  auth_provider auth_provider [not null, default: 'local']

  first_name varchar(100) [not null]
  last_name varchar(100) [not null]
  display_name varchar(150)
  phone varchar(30)
  avatar_url text

  status user_status [not null, default: 'pending']
  is_super_admin boolean [not null, default: false]
  email_verified_at timestamptz
  last_login_at timestamptz
  last_seen_at timestamptz

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz

  indexes {
    email
    username
    status
  }

  Note: '''
  Utilisateur plateforme.
  password_hash peut être null si authentification SSO/OAuth uniquement.
  '''
}

Table roles {
  id uuid [pk, not null]
  code varchar(50) [not null, unique]
  name varchar(100) [not null]
  description text
  is_system boolean [not null, default: false]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Note: '''
  Exemples :
  SUPER_ADMIN, ORG_ADMIN, DESIGNER, FACILITATOR, OBSERVER, PARTICIPANT, EVALUATOR
  '''
}

Table permissions {
  id uuid [pk, not null]
  code varchar(100) [not null, unique]
  name varchar(150) [not null]
  description text
  resource varchar(100)
  action varchar(50)

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Note: 'Optionnel mais recommandé pour un RBAC évolutif'
}

Table role_permissions {
  role_id uuid [not null, ref: > roles.id]
  permission_id uuid [not null, ref: > permissions.id]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (role_id, permission_id) [pk]
  }
}

Table organization_members {
  id uuid [pk, not null]
  organization_id uuid [not null, ref: > organizations.id]
  user_id uuid [not null, ref: > users.id]

  job_title varchar(100)
  department varchar(100)
  status membership_status [not null, default: 'invited']
  joined_at timestamptz
  invited_at timestamptz [not null, default: `now()`]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz

  indexes {
    (organization_id, user_id) [unique]
    organization_id
    user_id
    status
  }

  Note: 'Lien entre un utilisateur et une organisation'
}

Table user_global_roles {
  id uuid [pk, not null]
  user_id uuid [not null, ref: > users.id]
  role_id uuid [not null, ref: > roles.id]
  assigned_by uuid [ref: > users.id]

  created_at timestamptz [not null, default: `now()`]

  indexes {
    (user_id, role_id) [unique]
    user_id
    role_id
  }

  Note: 'Rôles globaux plateforme, ex: SUPER_ADMIN'
}

Table organization_member_roles {
  id uuid [pk, not null]
  organization_member_id uuid [not null, ref: > organization_members.id]
  role_id uuid [not null, ref: > roles.id]
  assigned_by uuid [ref: > users.id]

  created_at timestamptz [not null, default: `now()`]

  indexes {
    (organization_member_id, role_id) [unique]
    organization_member_id
    role_id
  }

  Note: 'Rôles attribués à un membre dans une organisation'
}

Table user_sessions {
  id uuid [pk, not null]
  user_id uuid [not null, ref: > users.id]

  refresh_token_hash text [not null]
  ip_address inet
  user_agent text
  expires_at timestamptz [not null]
  revoked_at timestamptz
  last_used_at timestamptz

  created_at timestamptz [not null, default: `now()`]

  indexes {
    user_id
    expires_at
  }

  Note: 'Gestion des sessions persistantes / refresh tokens'
}

Table auth_tokens {
  id uuid [pk, not null]
  user_id uuid [not null, ref: > users.id]

  token_hash text [not null]
  token_type token_type [not null]
  expires_at timestamptz [not null]
  used_at timestamptz

  created_at timestamptz [not null, default: `now()`]

  indexes {
    user_id
    token_type
    expires_at
  }

  Note: 'Tokens de reset mot de passe, vérification email, magic link'
}

Table user_audit_logs {
  id bigserial [pk, not null]
  user_id uuid [ref: > users.id]
  actor_user_id uuid [ref: > users.id]

  event_type varchar(100) [not null]
  event_data jsonb
  ip_address inet
  user_agent text

  created_at timestamptz [not null, default: `now()`]

  indexes {
    user_id
    actor_user_id
    event_type
    created_at
  }

  Note: '''
  Exemples :
  USER_CREATED, LOGIN_SUCCESS, LOGIN_FAILED, PASSWORD_CHANGED, USER_DISABLED, ROLE_ASSIGNED
  '''
}






// SCENARIO

Enum crisis_domain_status {
  active
  inactive
  archived
}

Enum scenario_status {
  draft
  review
  published
  archived
}

Enum scenario_visibility {
  private
  organization
  public_catalog
}

Enum difficulty_level {
  very_easy
  easy
  medium
  hard
  expert
  custom
}

Enum duration_unit {
  minutes
  hours
  days
}

Enum node_type {
  start
  narrative
  decision
  inject
  incident
  task
  consequence
  branch
  delay
  checkpoint
  end_success
  end_failure
  end_neutral
}

Enum choice_type {
  single
  multiple
  timed
  hidden
  automatic
}

Enum condition_operator {
  eq
  neq
  gt
  gte
  lt
  lte
  in
  not_in
  contains
  not_contains
  is_true
  is_false
  changed
}

Enum trigger_type {
  manual
  automatic
  scheduled
  conditional
  immediate
}

Enum trigger_source {
  timeline
  player_choice
  facilitator_action
  system_rule
  ai_engine
}

Enum inject_type {
  email
  sms
  phone_call
  media_call
  social_post
  press_release
  alert
  internal_message
  authority_notice
  field_report
  system_failure
  physical_incident
  document_drop
  meeting_request
  rumor
  custom
}

Enum inject_channel {
  email
  sms
  phone
  dashboard
  chat
  press
  radio
  tv
  social_network
  official_letter
  in_person
  custom
}

Enum inject_priority {
  low
  medium
  high
  critical
}

Enum rule_action_type {
  set_variable
  increment_variable
  decrement_variable
  set_status
  activate_node
  deactivate_node
  trigger_inject
  unlock_choice
  lock_choice
  add_tag
  remove_tag
  score_change
  timer_change
  end_scenario
  custom
}

Enum scenario_variable_type {
  integer
  float
  boolean
  text
  json
}

Enum resource_type {
  document
  image
  audio
  video
  map
  checklist
  procedure
  contact_sheet
  press_template
  report
  custom
}

Enum actor_role_type {
  internal
  external
  authority
  media
  civilian
  supplier
  partner
  emergency_service
  attacker
  victim
  custom
}

Enum scenario_mode {
  scripted
  semi_dynamic
  ai_driven
  hybrid
}

Table crisis_domains {
  id uuid [pk, not null]
  code varchar(50) [not null, unique]
  name varchar(150) [not null]
  description text
  status crisis_domain_status [not null, default: 'active']

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Note: '''
  Familles globales de crise.
  Exemples :
  CYBER, FIRE, HR, NATURAL_DISASTER, PANDEMIC, INDUSTRIAL, REPUTATIONAL
  '''
}

Table crisis_types {
  id uuid [pk, not null]
  crisis_domain_id uuid [not null, ref: > crisis_domains.id]

  code varchar(50) [not null, unique]
  name varchar(150) [not null]
  short_description varchar(255)
  description text

  default_severity_min int [not null, default: 1]
  default_severity_max int [not null, default: 5]

  is_active boolean [not null, default: true]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    crisis_domain_id
    name
    is_active
  }

  Note: '''
  Types précis de crises.
  Exemples :
  ransomware, data_breach, building_fire, workplace_harassment, flood, pandemic_cluster
  '''
}

Table crisis_subtypes {
  id uuid [pk, not null]
  crisis_type_id uuid [not null, ref: > crisis_types.id]

  code varchar(50) [not null, unique]
  name varchar(150) [not null]
  description text
  is_active boolean [not null, default: true]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    crisis_type_id
    is_active
  }

  Note: 'Sous-catégories facultatives pour une granularité plus fine'
}

Table scenario_tags {
  id uuid [pk, not null]
  code varchar(50) [not null, unique]
  name varchar(100) [not null]
  category varchar(100)
  description text

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Note: '''
  Exemples :
  public_health, multi_site, high_media_pressure, regulatory, schools, hospital, transport
  '''
}

Table scenarios {
  id uuid [pk, not null]
  crisis_type_id uuid [not null, ref: > crisis_types.id]
  primary_subtype_id uuid [ref: > crisis_subtypes.id]

  code varchar(50) [not null, unique]
  title varchar(200) [not null]
  slug varchar(200) [not null, unique]
  summary varchar(500)
  description text
  learning_objectives text
  facilitator_notes text

  status scenario_status [not null, default: 'draft']
  visibility scenario_visibility [not null, default: 'private']
  mode scenario_mode [not null, default: 'scripted']

  default_difficulty difficulty_level [not null, default: 'medium']
  difficulty_score int [not null, default: 50]
  min_duration_value int [not null, default: 30]
  min_duration_unit duration_unit [not null, default: 'minutes']
  max_duration_value int [not null, default: 120]
  max_duration_unit duration_unit [not null, default: 'minutes']
  recommended_duration_minutes int [not null, default: 60]

  min_players int [not null, default: 1]
  max_players int [not null, default: 20]
  is_template boolean [not null, default: true]
  version int [not null, default: 1]

  created_by uuid
  updated_by uuid

  published_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  archived_at timestamptz

  indexes {
    crisis_type_id
    primary_subtype_id
    status
    visibility
    default_difficulty
    mode
    title
  }

  Note: 'Scénario éditorial principal'
}

Table scenario_tag_links {
  scenario_id uuid [not null, ref: > scenarios.id]
  tag_id uuid [not null, ref: > scenario_tags.id]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (scenario_id, tag_id) [pk]
    tag_id
  }
}

Table scenario_versions {
  id uuid [pk, not null]
  scenario_id uuid [not null, ref: > scenarios.id]

  version_number int [not null]
  title varchar(200) [not null]
  changelog text
  snapshot_data jsonb [not null]
  created_by uuid
  created_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_id
    (scenario_id, version_number) [unique]
  }

  Note: 'Historique éditorial complet du scénario'
}

Table scenario_difficulty_profiles {
  id uuid [pk, not null]
  scenario_id uuid [not null, ref: > scenarios.id]

  code varchar(50) [not null]
  name varchar(100) [not null]
  level difficulty_level [not null, default: 'custom']
  description text

  time_pressure_factor numeric(6,2) [not null, default: 1.00]
  inject_frequency_factor numeric(6,2) [not null, default: 1.00]
  information_noise_factor numeric(6,2) [not null, default: 1.00]
  resource_scarcity_factor numeric(6,2) [not null, default: 1.00]
  decision_time_limit_seconds int
  hidden_information_enabled boolean [not null, default: false]
  parallel_events_enabled boolean [not null, default: false]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_id
    (scenario_id, code) [unique]
    level
  }

  Note: 'Profils de difficulté paramétrables par scénario'
}

Table scenario_duration_profiles {
  id uuid [pk, not null]
  scenario_id uuid [not null, ref: > scenarios.id]

  code varchar(50) [not null]
  name varchar(100) [not null]
  description text

  target_duration_minutes int [not null]
  max_duration_minutes int
  pacing_factor numeric(6,2) [not null, default: 1.00]
  compress_timeline boolean [not null, default: false]
  allow_skip_delays boolean [not null, default: false]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_id
    (scenario_id, code) [unique]
  }

  Note: 'Profils de durée : version courte, standard, longue, intense, etc.'
}

Table scenario_variables {
  id uuid [pk, not null]
  scenario_id uuid [not null, ref: > scenarios.id]

  code varchar(100) [not null]
  name varchar(150) [not null]
  description text
  variable_type scenario_variable_type [not null]

  default_value_text text
  default_value_json jsonb

  is_system boolean [not null, default: false]
  is_required boolean [not null, default: false]
  is_visible_to_facilitator boolean [not null, default: true]
  is_visible_to_players boolean [not null, default: false]

  min_value numeric(12,2)
  max_value numeric(12,2)

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_id
    (scenario_id, code) [unique]
    variable_type
  }

  Note: '''
  Variables du moteur.
  Exemples :
  panic_level, media_pressure, system_availability, casualties_count, regulatory_risk
  '''
}

Table scenario_actors {
  id uuid [pk, not null]
  scenario_id uuid [not null, ref: > scenarios.id]

  code varchar(50) [not null]
  name varchar(150) [not null]
  actor_role_type actor_role_type [not null, default: 'custom']
  title varchar(150)
  organization_name varchar(150)

  description text
  contact_info jsonb
  metadata jsonb

  is_playable boolean [not null, default: false]
  is_system_actor boolean [not null, default: false]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_id
    (scenario_id, code) [unique]
    actor_role_type
  }

  Note: '''
  Acteurs présents dans le scénario :
  DG, RSSI, journaliste, maire, pompier, hôpital, fournisseur, attaquant...
  '''
}

Table scenario_resources {
  id uuid [pk, not null]
  scenario_id uuid [not null, ref: > scenarios.id]

  code varchar(50) [not null]
  name varchar(200) [not null]
  resource_type resource_type [not null]
  description text

  file_url text
  external_url text
  content_text text
  metadata jsonb

  is_public_to_players boolean [not null, default: false]
  is_public_to_facilitators boolean [not null, default: true]
  is_required boolean [not null, default: false]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_id
    (scenario_id, code) [unique]
    resource_type
  }

  Note: 'Documents, cartes, fiches réflexes, procédures, communiqués, pièces jointes...'
}

Table scenario_structure {
  id uuid [pk, not null]
  scenario_id uuid [not null, ref: > scenarios.id]

  name varchar(150) [not null]
  description text
  start_node_id uuid
  is_default boolean [not null, default: true]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_id
  }

  Note: '''
  Permet d'avoir plusieurs structures narratives pour un même scénario si besoin.
  start_node_id référencé logiquement vers scenario_nodes.id.
  '''
}

Table scenario_nodes {
  id uuid [pk, not null]
  structure_id uuid [not null, ref: > scenario_structure.id]
  scenario_id uuid [not null, ref: > scenarios.id]

  code varchar(100) [not null]
  title varchar(200) [not null]
  node_type node_type [not null]
  description text
  narrative_text text
  facilitator_text text

  position_x int [not null, default: 0]
  position_y int [not null, default: 0]

  sequence_order int
  is_entry_point boolean [not null, default: false]
  is_terminal boolean [not null, default: false]
  is_active_by_default boolean [not null, default: true]
  auto_enter boolean [not null, default: false]

  estimated_duration_seconds int
  decision_time_limit_seconds int
  metadata jsonb

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_id
    structure_id
    (structure_id, code) [unique]
    node_type
    is_entry_point
    is_terminal
  }

  Note: '''
  Noeuds de l'arbre narratif :
  scène, incident, choix, conséquence, checkpoint, fin...
  '''
}

Table node_resources {
  node_id uuid [not null, ref: > scenario_nodes.id]
  resource_id uuid [not null, ref: > scenario_resources.id]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (node_id, resource_id) [pk]
    resource_id
  }
}

Table node_actors {
  node_id uuid [not null, ref: > scenario_nodes.id]
  actor_id uuid [not null, ref: > scenario_actors.id]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (node_id, actor_id) [pk]
    actor_id
  }

  Note: 'Acteurs impliqués dans un noeud donné'
}

Table node_choices {
  id uuid [pk, not null]
  node_id uuid [not null, ref: > scenario_nodes.id]

  code varchar(100) [not null]
  label varchar(255) [not null]
  description text
  choice_type choice_type [not null, default: 'single']

  display_order int [not null, default: 1]
  is_default boolean [not null, default: false]
  is_hidden boolean [not null, default: false]
  is_enabled_by_default boolean [not null, default: true]

  time_cost_seconds int
  metadata jsonb

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    node_id
    (node_id, code) [unique]
    display_order
  }

  Note: 'Choix offerts au joueur sur un noeud de décision'
}

Table node_edges {
  id uuid [pk, not null]
  structure_id uuid [not null, ref: > scenario_structure.id]

  from_node_id uuid [not null, ref: > scenario_nodes.id]
  to_node_id uuid [not null, ref: > scenario_nodes.id]
  via_choice_id uuid [ref: > node_choices.id]

  label varchar(150)
  description text
  priority int [not null, default: 100]
  is_default_path boolean [not null, default: false]
  is_active boolean [not null, default: true]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    structure_id
    from_node_id
    to_node_id
    via_choice_id
  }

  Note: '''
  Arêtes de l'arbre / graphe narratif.
  via_choice_id peut être null pour transitions automatiques.
  '''
}

Table edge_conditions {
  id uuid [pk, not null]
  edge_id uuid [not null, ref: > node_edges.id]

  variable_code varchar(100) [not null]
  operator condition_operator [not null]
  expected_value_text text
  expected_value_json jsonb

  sort_order int [not null, default: 1]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    edge_id
    variable_code
  }

  Note: 'Conditions pour suivre une branche donnée'
}

Table scenario_rules {
  id uuid [pk, not null]
  scenario_id uuid [not null, ref: > scenarios.id]

  code varchar(100) [not null]
  name varchar(150) [not null]
  description text

  is_active boolean [not null, default: true]
  priority int [not null, default: 100]
  source trigger_source [not null, default: 'system_rule']

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_id
    (scenario_id, code) [unique]
    is_active
    priority
  }

  Note: 'Règles génériques de moteur pour le scénario'
}

Table rule_conditions {
  id uuid [pk, not null]
  rule_id uuid [not null, ref: > scenario_rules.id]

  variable_code varchar(100) [not null]
  operator condition_operator [not null]
  expected_value_text text
  expected_value_json jsonb

  logical_group varchar(50) [not null, default: 'default']
  sort_order int [not null, default: 1]

  created_at timestamptz [not null, default: `now()`]

  indexes {
    rule_id
    variable_code
  }
}

Table rule_actions {
  id uuid [pk, not null]
  rule_id uuid [not null, ref: > scenario_rules.id]

  action_type rule_action_type [not null]
  target_type varchar(50)
  target_id uuid
  target_code varchar(100)

  value_text text
  value_json jsonb

  sort_order int [not null, default: 1]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    rule_id
    action_type
    target_code
  }

  Note: '''
  Exemples :
  - increment_variable(media_pressure, +10)
  - trigger_inject(INJECT_003)
  - activate_node(NODE_014)
  - end_scenario(failure)
  '''
}

Table scenario_injects {
  id uuid [pk, not null]
  scenario_id uuid [not null, ref: > scenarios.id]
  related_node_id uuid [ref: > scenario_nodes.id]
  sender_actor_id uuid [ref: > scenario_actors.id]
  target_actor_id uuid [ref: > scenario_actors.id]

  code varchar(100) [not null]
  title varchar(200) [not null]
  inject_type inject_type [not null]
  channel inject_channel [not null]
  priority inject_priority [not null, default: 'medium']

  subject varchar(255)
  body_text text
  payload_json jsonb
  facilitator_instructions text

  is_manual_only boolean [not null, default: false]
  is_repeatable boolean [not null, default: false]
  is_hidden_from_players boolean [not null, default: false]

  base_delay_seconds int
  valid_from_offset_seconds int
  valid_until_offset_seconds int

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_id
    related_node_id
    (scenario_id, code) [unique]
    inject_type
    channel
    priority
  }

  Note: '''
  Événements injectables :
  journaliste qui appelle, bâtiment qui s'effondre, SI qui tombe, email d'alerte, etc.
  '''
}

Table inject_resources {
  inject_id uuid [not null, ref: > scenario_injects.id]
  resource_id uuid [not null, ref: > scenario_resources.id]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (inject_id, resource_id) [pk]
    resource_id
  }

  Note: 'Pièces jointes ou documents associés à un inject'
}

Table inject_triggers {
  id uuid [pk, not null]
  inject_id uuid [not null, ref: > scenario_injects.id]

  trigger_type trigger_type [not null]
  trigger_source trigger_source [not null, default: 'timeline']

  name varchar(150) [not null]
  description text

  scheduled_offset_seconds int
  relative_to_node_id uuid [ref: > scenario_nodes.id]
  relative_to_choice_id uuid [ref: > node_choices.id]

  auto_fire boolean [not null, default: true]
  cooldown_seconds int
  max_trigger_count int [not null, default: 1]

  is_active boolean [not null, default: true]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    inject_id
    trigger_type
    trigger_source
    is_active
  }

  Note: '''
  Déclenchement :
  - programmé dans la timeline
  - après un choix
  - manuel par facilitateur
  - conditionnel selon variables
  '''
}

Table inject_trigger_conditions {
  id uuid [pk, not null]
  trigger_id uuid [not null, ref: > inject_triggers.id]

  variable_code varchar(100) [not null]
  operator condition_operator [not null]
  expected_value_text text
  expected_value_json jsonb

  sort_order int [not null, default: 1]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    trigger_id
    variable_code
  }
}

Table inject_effects {
  id uuid [pk, not null]
  inject_id uuid [not null, ref: > scenario_injects.id]

  action_type rule_action_type [not null]
  target_type varchar(50)
  target_id uuid
  target_code varchar(100)

  value_text text
  value_json jsonb

  sort_order int [not null, default: 1]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    inject_id
    action_type
  }

  Note: 'Effets produits lorsqu’un inject est exécuté'
}

Table scenario_timeline_markers {
  id uuid [pk, not null]
  scenario_id uuid [not null, ref: > scenarios.id]
  related_node_id uuid [ref: > scenario_nodes.id]
  related_inject_id uuid [ref: > scenario_injects.id]

  code varchar(100) [not null]
  name varchar(150) [not null]
  description text

  offset_seconds int [not null]
  is_milestone boolean [not null, default: false]
  is_optional boolean [not null, default: false]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_id
    (scenario_id, code) [unique]
    offset_seconds
  }

  Note: 'Repères de chronologie pour visualisation ou orchestration'
}

Table scenario_outcomes {
  id uuid [pk, not null]
  scenario_id uuid [not null, ref: > scenarios.id]

  code varchar(50) [not null]
  name varchar(150) [not null]
  description text

  outcome_score_min int
  outcome_score_max int
  is_success boolean [not null, default: false]
  is_failure boolean [not null, default: false]
  is_neutral boolean [not null, default: false]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_id
    (scenario_id, code) [unique]
  }

  Note: 'Issues possibles du scénario'
}

Table scenario_checkpoints {
  id uuid [pk, not null]
  scenario_id uuid [not null, ref: > scenarios.id]
  node_id uuid [ref: > scenario_nodes.id]

  code varchar(100) [not null]
  name varchar(150) [not null]
  description text

  required boolean [not null, default: false]
  sort_order int [not null, default: 1]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_id
    (scenario_id, code) [unique]
    sort_order
  }

  Note: 'Points de contrôle pédagogiques ou narratifs'
}

Table checkpoint_conditions {
  id uuid [pk, not null]
  checkpoint_id uuid [not null, ref: > scenario_checkpoints.id]

  variable_code varchar(100) [not null]
  operator condition_operator [not null]
  expected_value_text text
  expected_value_json jsonb

  sort_order int [not null, default: 1]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    checkpoint_id
    variable_code
  }
}

Table scenario_balancing_profiles {
  id uuid [pk, not null]
  scenario_id uuid [not null, ref: > scenarios.id]

  code varchar(50) [not null]
  name varchar(100) [not null]
  description text

  player_count_min int
  player_count_max int

  inject_density_factor numeric(6,2) [not null, default: 1.00]
  decision_complexity_factor numeric(6,2) [not null, default: 1.00]
  branching_factor numeric(6,2) [not null, default: 1.00]
  chaos_factor numeric(6,2) [not null, default: 1.00]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_id
    (scenario_id, code) [unique]
  }

  Note: 'Ajustement selon le nombre de joueurs ou le mode d’animation'
}

Table scenario_ai_settings {
  id uuid [pk, not null]
  scenario_id uuid [not null, ref: > scenarios.id]

  ai_enabled boolean [not null, default: false]
  ai_director_enabled boolean [not null, default: false]
  ai_actor_simulation_enabled boolean [not null, default: false]
  ai_dynamic_injects_enabled boolean [not null, default: false]
  ai_auto_escalation_enabled boolean [not null, default: false]

  generation_policy jsonb
  moderation_policy jsonb
  fallback_policy jsonb

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_id [unique]
  }

  Note: 'Préparation du mode IA sans lier le modèle à un fournisseur spécifique'
}


// Tableau de bord opérationnel / Cellule de crise

Enum run_status {
  pending
  ready
  running
  paused
  completed
  cancelled
  archived
}

Enum dashboard_status {
  inactive
  active
  locked
  archived
}

Enum map_layer_type {
  base_map
  hot_zone
  affected_zone
  safe_zone
  resource_zone
  incident_zone
  evacuation_zone
  route
  perimeter
  custom
}

Enum map_object_type {
  marker
  polygon
  polyline
  circle
  heatspot
  icon
  resource
  incident
  checkpoint
  custom
}

Enum situation_object_status {
  normal
  watch
  degraded
  critical
  resolved
  unavailable
}

Enum resource_category {
  human
  vehicle
  equipment
  medical
  security
  logistics
  communication
  facility
  stock
  it_asset
  custom
}

Enum resource_status {
  available
  allocated
  en_route
  busy
  damaged
  lost
  unavailable
}

Enum timeline_event_type {
  inject
  incident
  decision
  action
  alert
  communication
  escalation
  resolution
  note
  checkpoint
  system
}

Enum timeline_visibility {
  facilitator_only
  staff_only
  all
}

Enum decision_status {
  proposed
  approved
  rejected
  executed
  cancelled
  expired
}

Enum indicator_type {
  media_pressure
  team_morale
  resource_capacity
  public_confidence
  operational_load
  regulatory_risk
  safety_level
  infrastructure_status
  service_continuity
  custom
}

Enum indicator_trend {
  stable
  rising
  falling
  volatile
}

Enum room_role_type {
  director
  communication
  logistics
  operations
  security
  legal
  hr
  medical
  it
  liaison
  observer
  analyst
  custom
}

Enum room_post_status {
  vacant
  occupied
  standby
  unavailable
}

Enum task_status {
  pending
  in_progress
  blocked
  done
  cancelled
}

Enum task_priority {
  low
  medium
  high
  critical
}

Enum widget_type {
  map
  timeline
  indicators
  room_overview
  task_board
  activity_feed
  decision_panel
  resources_panel
  communications_panel
  custom
}

Enum widget_scope {
  personal
  room
  global
}

Table simulation_runs {
  id uuid [pk, not null]
  scenario_id uuid [not null]
  name varchar(200) [not null]
  code varchar(100) [not null, unique]

  status run_status [not null, default: 'pending']
  started_at timestamptz
  paused_at timestamptz
  ended_at timestamptz

  current_time_offset_seconds int [not null, default: 0]
  difficulty_code varchar(50)
  duration_profile_code varchar(50)

  created_by uuid
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_id
    status
    started_at
  }

  Note: 'Instance réelle d’exécution d’un scénario'
}

Table operational_dashboards {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  name varchar(150) [not null]
  status dashboard_status [not null, default: 'active']
  is_main boolean [not null, default: true]

  layout_config jsonb
  display_config jsonb
  refresh_interval_seconds int [not null, default: 5]

  created_by uuid
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    status
  }

  Note: 'Dashboard opérationnel principal ou secondaire pour un run'
}

Table dashboard_widgets {
  id uuid [pk, not null]
  dashboard_id uuid [not null, ref: > operational_dashboards.id]

  code varchar(100) [not null]
  title varchar(150) [not null]
  widget_type widget_type [not null]
  scope widget_scope [not null, default: 'global']

  pos_x int [not null, default: 0]
  pos_y int [not null, default: 0]
  width int [not null, default: 4]
  height int [not null, default: 4]

  is_visible boolean [not null, default: true]
  is_locked boolean [not null, default: false]

  config jsonb
  filters jsonb

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    dashboard_id
    (dashboard_id, code) [unique]
    widget_type
  }

  Note: 'Widgets affichés sur le tableau de bord'
}

Table situation_maps {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]
  dashboard_id uuid [ref: > operational_dashboards.id]

  name varchar(150) [not null]
  description text
  base_map_name varchar(150)
  map_provider varchar(100)

  center_lat numeric(10,7)
  center_lng numeric(10,7)
  default_zoom int [not null, default: 12]

  bounds_json jsonb
  settings jsonb

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    dashboard_id
  }

  Note: 'Carte de situation principale ou cartes spécialisées'
}

Table map_layers {
  id uuid [pk, not null]
  map_id uuid [not null, ref: > situation_maps.id]

  code varchar(100) [not null]
  name varchar(150) [not null]
  layer_type map_layer_type [not null]

  display_order int [not null, default: 1]
  is_visible boolean [not null, default: true]
  is_toggleable boolean [not null, default: true]

  style_config jsonb
  filter_config jsonb

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    map_id
    (map_id, code) [unique]
    layer_type
  }

  Note: 'Couches d’affichage de la carte'
}

Table map_objects {
  id uuid [pk, not null]
  layer_id uuid [not null, ref: > map_layers.id]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100) [not null]
  name varchar(150) [not null]
  object_type map_object_type [not null]
  status situation_object_status [not null, default: 'normal']

  geometry jsonb [not null]
  center_lat numeric(10,7)
  center_lng numeric(10,7)

  severity_level int [not null, default: 1]
  label varchar(150)
  description text
  metadata jsonb

  related_event_id uuid
  related_resource_id uuid
  related_zone_id uuid

  is_clickable boolean [not null, default: true]
  is_draggable boolean [not null, default: false]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  resolved_at timestamptz

  indexes {
    layer_id
    simulation_run_id
    (layer_id, code) [unique]
    object_type
    status
    severity_level
  }

  Note: '''
  Éléments affichés sur la carte :
  point chaud, zone touchée, ressource, incident, route, périmètre...
  geometry au format GeoJSON-like stocké en jsonb
  '''
}

Table operational_zones {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100) [not null]
  name varchar(150) [not null]
  description text

  zone_type varchar(100)
  status situation_object_status [not null, default: 'normal']
  severity_level int [not null, default: 1]

  geometry jsonb
  center_lat numeric(10,7)
  center_lng numeric(10,7)

  population_estimate int
  impact_level int [not null, default: 1]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  resolved_at timestamptz

  indexes {
    simulation_run_id
    (simulation_run_id, code) [unique]
    status
    severity_level
  }

  Note: 'Zones affectées, sécurisées, évacuées, à surveiller, etc.'
}

Table operational_resources {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100) [not null]
  name varchar(150) [not null]
  category resource_category [not null]
  status resource_status [not null, default: 'available']

  quantity_total numeric(12,2) [not null, default: 1]
  quantity_available numeric(12,2) [not null, default: 1]
  unit varchar(50)

  location_text varchar(255)
  current_lat numeric(10,7)
  current_lng numeric(10,7)

  assigned_zone_id uuid [ref: > operational_zones.id]
  metadata jsonb
  notes text

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    (simulation_run_id, code) [unique]
    category
    status
    assigned_zone_id
  }

  Note: '''
  Ressources de crise :
  équipes, véhicules, stock médical, radios, groupes électrogènes, serveurs, etc.
  '''
}

Table resource_movements {
  id uuid [pk, not null]
  resource_id uuid [not null, ref: > operational_resources.id]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  from_zone_id uuid [ref: > operational_zones.id]
  to_zone_id uuid [ref: > operational_zones.id]

  moved_quantity numeric(12,2)
  departure_at timestamptz
  arrival_at timestamptz
  status resource_status [not null, default: 'en_route']

  notes text
  created_by uuid
  created_at timestamptz [not null, default: `now()`]

  indexes {
    resource_id
    simulation_run_id
    from_zone_id
    to_zone_id
    status
  }

  Note: 'Historique de déplacement ou réaffectation des ressources'
}

Table operational_timeline_events {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100)
  title varchar(200) [not null]
  description text
  event_type timeline_event_type [not null]
  visibility timeline_visibility [not null, default: 'all']

  event_time timestamptz [not null]
  relative_offset_seconds int
  sort_order int [not null, default: 1]

  severity_level int [not null, default: 1]
  related_node_id uuid
  related_inject_id uuid
  related_decision_id uuid
  related_zone_id uuid [ref: > operational_zones.id]
  related_resource_id uuid [ref: > operational_resources.id]

  created_by uuid
  metadata jsonb

  created_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    event_time
    event_type
    visibility
    severity_level
  }

  Note: 'Timeline chronologique centrale des événements'
}

Table operational_decisions {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100)
  title varchar(200) [not null]
  description text

  proposed_by uuid
  approved_by uuid
  executed_by uuid

  status decision_status [not null, default: 'proposed']
  priority task_priority [not null, default: 'medium']

  proposed_at timestamptz [not null, default: `now()`]
  decided_at timestamptz
  executed_at timestamptz
  expires_at timestamptz

  related_zone_id uuid [ref: > operational_zones.id]
  related_resource_id uuid [ref: > operational_resources.id]

  expected_impact jsonb
  actual_impact jsonb
  notes text

  indexes {
    simulation_run_id
    status
    priority
    proposed_at
    related_zone_id
  }

  Note: 'Décisions prises ou proposées dans la cellule de crise'
}

Table decision_actions {
  id uuid [pk, not null]
  decision_id uuid [not null, ref: > operational_decisions.id]

  action_label varchar(200) [not null]
  action_type varchar(100)
  target_type varchar(100)
  target_id uuid

  action_order int [not null, default: 1]
  action_payload jsonb
  execution_status task_status [not null, default: 'pending']

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    decision_id
    execution_status
    action_order
  }

  Note: 'Sous-actions concrètes rattachées à une décision'
}

Table pressure_indicators {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100) [not null]
  name varchar(150) [not null]
  indicator_type indicator_type [not null]

  current_value numeric(12,2) [not null, default: 0]
  min_value numeric(12,2) [not null, default: 0]
  max_value numeric(12,2) [not null, default: 100]

  normalized_score numeric(6,2)
  trend indicator_trend [not null, default: 'stable']
  trend_delta numeric(12,2) [not null, default: 0]

  unit varchar(50)
  color_hint varchar(30)
  description text

  calculation_mode varchar(50) [not null, default: 'manual']
  formula_config jsonb

  last_updated_at timestamptz [not null, default: `now()`]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    (simulation_run_id, code) [unique]
    indicator_type
    trend
  }

  Note: '''
  Exemples :
  media_pressure, team_morale, remaining_resources, public_confidence, service_availability
  '''
}

Table indicator_history {
  id bigserial [pk, not null]
  indicator_id uuid [not null, ref: > pressure_indicators.id]

  recorded_at timestamptz [not null, default: `now()`]
  value numeric(12,2) [not null]
  normalized_score numeric(6,2)
  trend indicator_trend
  trend_delta numeric(12,2)

  source_event_id uuid [ref: > operational_timeline_events.id]
  metadata jsonb

  indexes {
    indicator_id
    recorded_at
    source_event_id
  }

  Note: 'Historique des indicateurs pour graphiques et analyse'
}

Table crisis_rooms {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100) [not null]
  name varchar(150) [not null]
  description text

  is_main boolean [not null, default: true]
  room_status varchar(50) [not null, default: 'active']
  settings jsonb

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    (simulation_run_id, code) [unique]
  }

  Note: 'Salle de crise virtuelle ou sous-salle thématique'
}

Table room_posts {
  id uuid [pk, not null]
  room_id uuid [not null, ref: > crisis_rooms.id]

  code varchar(100) [not null]
  name varchar(150) [not null]
  room_role_type room_role_type [not null]
  status room_post_status [not null, default: 'vacant']

  display_order int [not null, default: 1]
  description text
  responsibilities text

  ui_position_x int [not null, default: 0]
  ui_position_y int [not null, default: 0]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    room_id
    (room_id, code) [unique]
    room_role_type
    status
  }

  Note: '''
  Postes virtuels :
  Directeur, Communication, Logistique, Opérations, Juridique, RH, etc.
  '''
}

Table room_post_assignments {
  id uuid [pk, not null]
  post_id uuid [not null, ref: > room_posts.id]
  user_id uuid [not null]

  assigned_at timestamptz [not null, default: `now()`]
  unassigned_at timestamptz
  is_primary boolean [not null, default: true]

  assigned_by uuid
  notes text

  indexes {
    post_id
    user_id
    assigned_at
  }

  Note: 'Affectation d’un utilisateur à un poste virtuel'
}

Table room_post_activity_logs {
  id bigserial [pk, not null]
  post_id uuid [not null, ref: > room_posts.id]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  activity_type varchar(100) [not null]
  title varchar(200)
  description text

  actor_user_id uuid
  related_event_id uuid [ref: > operational_timeline_events.id]
  related_decision_id uuid [ref: > operational_decisions.id]

  created_at timestamptz [not null, default: `now()`]

  indexes {
    post_id
    simulation_run_id
    activity_type
    created_at
  }

  Note: 'Journal métier d’un poste de la salle de crise'
}

Table operational_tasks {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]
  room_post_id uuid [ref: > room_posts.id]

  code varchar(100)
  title varchar(200) [not null]
  description text

  status task_status [not null, default: 'pending']
  priority task_priority [not null, default: 'medium']

  assigned_user_id uuid
  assigned_team_label varchar(150)

  related_event_id uuid [ref: > operational_timeline_events.id]
  related_decision_id uuid [ref: > operational_decisions.id]
  related_zone_id uuid [ref: > operational_zones.id]
  related_resource_id uuid [ref: > operational_resources.id]

  due_at timestamptz
  started_at timestamptz
  completed_at timestamptz

  progress_percent numeric(5,2) [not null, default: 0]
  notes text
  metadata jsonb

  created_by uuid
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    room_post_id
    status
    priority
    assigned_user_id
    due_at
  }

  Note: 'Tâches opérationnelles attribuées à un poste ou un utilisateur'
}

Table room_views {
  id uuid [pk, not null]
  room_id uuid [not null, ref: > crisis_rooms.id]
  dashboard_id uuid [ref: > operational_dashboards.id]

  code varchar(100) [not null]
  name varchar(150) [not null]
  description text

  view_config jsonb [not null]
  is_default boolean [not null, default: false]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    room_id
    (room_id, code) [unique]
  }

  Note: 'Vues prédéfinies : vue directeur, vue communication, vue logistique...'
}

Table room_announcements {
  id uuid [pk, not null]
  room_id uuid [not null, ref: > crisis_rooms.id]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  title varchar(200) [not null]
  message text [not null]
  severity_level int [not null, default: 1]

  posted_by uuid
  posted_at timestamptz [not null, default: `now()`]
  expires_at timestamptz

  related_event_id uuid [ref: > operational_timeline_events.id]
  metadata jsonb

  indexes {
    room_id
    simulation_run_id
    posted_at
    expires_at
    severity_level
  }

  Note: 'Annonces visibles dans la salle de crise'
}

Table operational_notes {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]
  room_id uuid [ref: > crisis_rooms.id]
  post_id uuid [ref: > room_posts.id]

  author_user_id uuid
  title varchar(200)
  content text [not null]

  visibility timeline_visibility [not null, default: 'staff_only']
  pinned boolean [not null, default: false]

  related_event_id uuid [ref: > operational_timeline_events.id]
  related_decision_id uuid [ref: > operational_decisions.id]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    room_id
    post_id
    author_user_id
    pinned
    created_at
  }

  Note: 'Prises de notes rapides dans la cellule de crise'
}

Table dashboard_snapshots {
  id uuid [pk, not null]
  dashboard_id uuid [not null, ref: > operational_dashboards.id]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  snapshot_time timestamptz [not null, default: `now()`]
  snapshot_data jsonb [not null]
  created_by uuid

  indexes {
    dashboard_id
    simulation_run_id
    snapshot_time
  }

  Note: 'Capture d’état du tableau de bord à un instant donné'
}


// Communication simulée

Enum communication_channel_type {
  direct_message
  team_channel
  crisis_room_channel
  broadcast_channel
  system_channel
  media_channel
  authority_channel
  custom
}

Enum communication_channel_status {
  active
  muted
  degraded
  offline
  archived
}

Enum message_type {
  text
  file
  alert
  decision_request
  status_update
  media_request
  authority_request
  rumor
  announcement
  custom
}

Enum delivery_status {
  queued
  delayed
  delivered
  failed
  dropped
  intercepted
  read
}

Enum outage_type {
  latency
  packet_loss
  channel_blackout
  sender_blackout
  receiver_blackout
  partial_delay
  total_outage
  custom
}

Enum media_source_type {
  twitter_like
  news_website
  tv
  radio
  blog
  journalist
  influencer
  press_agency
  forum
  custom
}

Enum media_item_type {
  tweet
  thread
  breaking_news
  article
  interview_request
  live_update
  rumor_post
  fact_check
  opinion_piece
  press_question
  custom
}

Enum media_tone {
  neutral
  favorable
  critical
  hostile
  alarmist
  speculative
}

Enum press_event_type {
  press_conference
  media_briefing
  interview
  press_statement
}

Enum press_event_status {
  planned
  open
  in_progress
  closed
  cancelled
}

Enum statement_status {
  draft
  submitted
  published
  withdrawn
  rejected
}

Enum statement_channel_type {
  press_release
  website
  internal_broadcast
  email
  social_post
  authority_notice
  live_speech
  custom
}

Enum evaluation_grade {
  very_poor
  poor
  average
  good
  excellent
}

Enum inbound_alert_type {
  phone_call
  email
  sms
  siren
  radio_message
  system_alarm
  social_ping
  authority_notice
  media_request
  witness_report
  custom
}

Enum inbound_alert_status {
  new
  acknowledged
  triaged
  assigned
  resolved
  ignored
  expired
}

Enum alert_priority_level {
  low
  medium
  high
  critical
}

Enum triage_decision {
  ignore
  monitor
  escalate
  delegate
  respond_now
}

Enum phone_call_status {
  ringing
  accepted
  missed
  voicemail
  dropped
  ended
}

Enum email_status {
  queued
  delivered
  opened
  replied
  bounced
  ignored
}

Enum social_reaction_type {
  like
  share
  comment
  outrage
  support
  misinformation
  fact_check
}

Table simulation_runs {
  id uuid [pk, not null]
  scenario_id uuid [not null]
  name varchar(200) [not null]
  code varchar(100) [not null, unique]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Note: 'Référence minimale vers une exécution de simulation'
}

Table communication_spaces {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100) [not null]
  name varchar(150) [not null]
  description text

  is_main boolean [not null, default: true]
  settings jsonb

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    (simulation_run_id, code) [unique]
  }

  Note: 'Espace global de communication d’une simulation'
}

Table communication_channels {
  id uuid [pk, not null]
  space_id uuid [not null, ref: > communication_spaces.id]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100) [not null]
  name varchar(150) [not null]
  description text

  channel_type communication_channel_type [not null]
  status communication_channel_status [not null, default: 'active']

  is_private boolean [not null, default: false]
  is_read_only boolean [not null, default: false]
  is_simulated boolean [not null, default: true]

  delivery_policy jsonb
  visibility_rules jsonb
  metadata jsonb

  created_by uuid
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  archived_at timestamptz

  indexes {
    space_id
    simulation_run_id
    (space_id, code) [unique]
    channel_type
    status
  }

  Note: '''
  Canaux de messagerie type Slack :
  #direction, #ops, #communication, DM, canal autorités, etc.
  '''
}

Table communication_channel_members {
  id uuid [pk, not null]
  channel_id uuid [not null, ref: > communication_channels.id]
  user_id uuid [not null]

  role_label varchar(100)
  joined_at timestamptz [not null, default: `now()`]
  left_at timestamptz

  is_admin boolean [not null, default: false]
  is_muted boolean [not null, default: false]

  indexes {
    channel_id
    user_id
    (channel_id, user_id, joined_at)
  }

  Note: 'Appartenance d’un utilisateur à un canal'
}

Table communication_threads {
  id uuid [pk, not null]
  channel_id uuid [not null, ref: > communication_channels.id]
  parent_message_id uuid

  title varchar(200)
  created_by uuid
  created_at timestamptz [not null, default: `now()`]
  closed_at timestamptz

  indexes {
    channel_id
    parent_message_id
  }

  Note: 'Threads de discussion dans un canal'
}

Table communication_messages {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]
  channel_id uuid [not null, ref: > communication_channels.id]
  thread_id uuid [ref: > communication_threads.id]

  sender_user_id uuid
  sender_actor_code varchar(100)
  sender_display_name varchar(150)

  message_type message_type [not null, default: 'text']
  subject varchar(255)
  body_text text [not null]
  rich_content jsonb

  sent_at timestamptz [not null, default: `now()`]
  scheduled_at timestamptz
  expires_at timestamptz

  priority alert_priority_level [not null, default: 'medium']
  is_system_generated boolean [not null, default: false]
  is_simulated boolean [not null, default: true]
  is_pinned boolean [not null, default: false]

  related_alert_id uuid
  related_statement_id uuid
  related_media_item_id uuid
  metadata jsonb

  indexes {
    simulation_run_id
    channel_id
    thread_id
    sent_at
    priority
    is_system_generated
  }

  Note: 'Messages internes ou simulés'
}

Table message_deliveries {
  id uuid [pk, not null]
  message_id uuid [not null, ref: > communication_messages.id]
  recipient_user_id uuid [not null]

  queued_at timestamptz [not null, default: `now()`]
  planned_delivery_at timestamptz
  delivered_at timestamptz
  read_at timestamptz

  delivery_delay_ms int [not null, default: 0]
  delivery_status delivery_status [not null, default: 'queued']
  failure_reason text

  metadata jsonb

  indexes {
    message_id
    recipient_user_id
    delivery_status
    planned_delivery_at
  }

  Note: 'Livraison individualisée pour simuler délais, perte ou lecture'
}

Table communication_outages {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]
  channel_id uuid [ref: > communication_channels.id]

  outage_type outage_type [not null]
  name varchar(150) [not null]
  description text

  started_at timestamptz [not null]
  ends_at timestamptz

  latency_ms int
  message_loss_percent numeric(5,2)
  affected_sender_user_id uuid
  affected_recipient_user_id uuid

  is_active boolean [not null, default: true]
  config jsonb

  created_by uuid
  created_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    channel_id
    outage_type
    is_active
    started_at
  }

  Note: '''
  Permet de simuler :
  - latence
  - messages perdus
  - coupure d’un canal
  - coupure d’un rôle spécifique
  '''
}

Table message_attachments {
  id uuid [pk, not null]
  message_id uuid [not null, ref: > communication_messages.id]

  file_name varchar(255) [not null]
  mime_type varchar(150)
  file_url text
  content_text text
  metadata jsonb

  created_at timestamptz [not null, default: `now()`]

  indexes {
    message_id
  }
}

Table media_streams {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100) [not null]
  name varchar(150) [not null]
  description text

  source_type media_source_type [not null]
  source_name varchar(150)
  credibility_score numeric(5,2) [not null, default: 50.00]
  influence_score numeric(5,2) [not null, default: 50.00]

  is_active boolean [not null, default: true]
  metadata jsonb

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    (simulation_run_id, code) [unique]
    source_type
    is_active
  }

  Note: 'Sources presse et réseaux sociaux simulés'
}

Table media_items {
  id uuid [pk, not null]
  stream_id uuid [not null, ref: > media_streams.id]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100)
  title varchar(255)
  body_text text [not null]

  media_item_type media_item_type [not null]
  tone media_tone [not null, default: 'neutral']
  urgency_level alert_priority_level [not null, default: 'medium']

  published_at timestamptz [not null, default: `now()`]
  scheduled_for timestamptz

  author_name varchar(150)
  author_handle varchar(150)

  estimated_reach int
  visibility_score numeric(6,2)
  credibility_score numeric(5,2)

  related_statement_id uuid
  related_alert_id uuid
  metadata jsonb

  indexes {
    stream_id
    simulation_run_id
    media_item_type
    tone
    published_at
    urgency_level
  }

  Note: '''
  Tweets, articles, breaking news, rumeurs, demandes d’interview, etc.
  '''
}

Table media_item_reactions {
  id bigserial [pk, not null]
  media_item_id uuid [not null, ref: > media_items.id]

  reaction_type social_reaction_type [not null]
  reaction_count int [not null, default: 0]
  measured_at timestamptz [not null, default: `now()`]

  sentiment_score numeric(5,2)
  metadata jsonb

  indexes {
    media_item_id
    reaction_type
    measured_at
  }

  Note: 'Mesure de propagation / réactions sociales'
}

Table press_events {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100) [not null]
  title varchar(200) [not null]
  description text

  press_event_type press_event_type [not null]
  status press_event_status [not null, default: 'planned']

  planned_start_at timestamptz
  actual_start_at timestamptz
  ended_at timestamptz

  moderator_name varchar(150)
  location_label varchar(150)
  configuration jsonb

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    (simulation_run_id, code) [unique]
    press_event_type
    status
    planned_start_at
  }

  Note: 'Conférence de presse ou briefing média à gérer'
}

Table press_questions {
  id uuid [pk, not null]
  press_event_id uuid [not null, ref: > press_events.id]

  source_stream_id uuid [ref: > media_streams.id]
  journalist_name varchar(150)
  question_text text [not null]

  priority alert_priority_level [not null, default: 'medium']
  asked_at timestamptz
  response_deadline_at timestamptz

  answered boolean [not null, default: false]
  answer_text text
  answered_at timestamptz

  metadata jsonb

  indexes {
    press_event_id
    source_stream_id
    priority
    asked_at
    answered
  }

  Note: 'Questions posées lors d’une conférence de presse'
}

Table official_statements {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100)
  title varchar(200) [not null]
  subject varchar(255)
  body_text text [not null]

  statement_status statement_status [not null, default: 'draft']
  channel_type statement_channel_type [not null]

  drafted_by uuid
  approved_by uuid
  published_by uuid

  drafted_at timestamptz [not null, default: `now()`]
  submitted_at timestamptz
  published_at timestamptz

  intended_audience varchar(150)
  key_messages jsonb
  metadata jsonb

  indexes {
    simulation_run_id
    statement_status
    channel_type
    published_at
  }

  Note: 'Communiqués officiels, déclarations, annonces'
}

Table statement_publications {
  id uuid [pk, not null]
  statement_id uuid [not null, ref: > official_statements.id]

  published_channel_label varchar(150) [not null]
  published_url text
  published_at timestamptz [not null, default: `now()`]

  estimated_reach int
  metadata jsonb

  indexes {
    statement_id
    published_at
  }

  Note: 'Historique multi-canal de publication'
}

Table statement_evaluations {
  id uuid [pk, not null]
  statement_id uuid [not null, ref: > official_statements.id]

  evaluated_at timestamptz [not null, default: `now()`]
  evaluated_by uuid

  clarity_score numeric(5,2) [not null, default: 0]
  speed_score numeric(5,2) [not null, default: 0]
  accuracy_score numeric(5,2) [not null, default: 0]
  consistency_score numeric(5,2) [not null, default: 0]
  empathy_score numeric(5,2) [not null, default: 0]

  overall_score numeric(5,2)
  clarity_grade evaluation_grade
  speed_grade evaluation_grade
  overall_grade evaluation_grade

  feedback_text text
  rubric_details jsonb

  indexes {
    statement_id
    evaluated_at
    overall_score
  }

  Note: 'Notation de la qualité d’un communiqué'
}

Table inbound_alert_queues {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100) [not null]
  name varchar(150) [not null]
  description text

  target_role_label varchar(100)
  is_default boolean [not null, default: false]
  settings jsonb

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    (simulation_run_id, code) [unique]
  }

  Note: 'Files d’arrivée d’alertes à traiter'
}

Table inbound_alerts {
  id uuid [pk, not null]
  queue_id uuid [not null, ref: > inbound_alert_queues.id]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100)
  title varchar(200) [not null]
  description text

  inbound_alert_type inbound_alert_type [not null]
  status inbound_alert_status [not null, default: 'new']
  priority alert_priority_level [not null, default: 'medium']

  source_name varchar(150)
  source_contact varchar(150)
  source_actor_code varchar(100)

  received_at timestamptz [not null, default: `now()`]
  must_ack_before timestamptz
  expires_at timestamptz

  triaged_at timestamptz
  resolved_at timestamptz

  related_zone_label varchar(150)
  related_statement_id uuid
  related_media_item_id uuid

  payload jsonb
  metadata jsonb

  indexes {
    queue_id
    simulation_run_id
    inbound_alert_type
    status
    priority
    received_at
    must_ack_before
  }

  Note: '''
  Appels, emails, sirènes, demandes presse, notifications autorités, alarmes SI...
  '''
}

Table inbound_alert_triage {
  id uuid [pk, not null]
  alert_id uuid [not null, ref: > inbound_alerts.id]

  decided_by uuid
  triage_decision triage_decision [not null]
  assigned_user_id uuid

  triaged_at timestamptz [not null, default: `now()`]
  rationale text
  response_deadline_at timestamptz

  metadata jsonb

  indexes {
    alert_id
    triage_decision
    assigned_user_id
    triaged_at
  }

  Note: 'Historique de priorisation / tri des alertes'
}

Table simulated_phone_calls {
  id uuid [pk, not null]
  alert_id uuid [not null, ref: > inbound_alerts.id]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  caller_name varchar(150)
  caller_number varchar(50)
  script_text text
  transcript_text text

  started_at timestamptz
  answered_at timestamptz
  ended_at timestamptz

  phone_call_status phone_call_status [not null, default: 'ringing']
  ring_duration_seconds int
  max_wait_seconds int

  recording_url text
  metadata jsonb

  indexes {
    alert_id
    simulation_run_id
    phone_call_status
    started_at
  }

  Note: 'Simulation d’appels entrants'
}

Table simulated_emails {
  id uuid [pk, not null]
  alert_id uuid [ref: > inbound_alerts.id]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  from_name varchar(150)
  from_email varchar(255)
  to_email varchar(255)
  cc_emails text
  bcc_emails text

  subject varchar(255) [not null]
  body_text text [not null]
  body_html text

  sent_at timestamptz [not null, default: `now()`]
  delivered_at timestamptz
  opened_at timestamptz
  replied_at timestamptz

  email_status email_status [not null, default: 'queued']
  metadata jsonb

  indexes {
    alert_id
    simulation_run_id
    email_status
    sent_at
  }

  Note: 'Simulation d’emails entrants ou sortants'
}

Table email_attachments {
  id uuid [pk, not null]
  email_id uuid [not null, ref: > simulated_emails.id]

  file_name varchar(255) [not null]
  mime_type varchar(150)
  file_url text
  content_text text
  metadata jsonb

  created_at timestamptz [not null, default: `now()`]

  indexes {
    email_id
  }
}

Table audible_alerts {
  id uuid [pk, not null]
  alert_id uuid [not null, ref: > inbound_alerts.id]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  sound_type varchar(100) [not null]
  label varchar(150)
  volume_level int [not null, default: 50]
  duration_seconds int
  loop_enabled boolean [not null, default: false]

  triggered_at timestamptz [not null, default: `now()`]
  stopped_at timestamptz

  metadata jsonb

  indexes {
    alert_id
    simulation_run_id
    triggered_at
  }

  Note: 'Sirènes, alarmes sonores, signaux urgents'
}

Table communication_scorecards {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  calculated_at timestamptz [not null, default: `now()`]

  responsiveness_score numeric(5,2) [not null, default: 0]
  prioritization_score numeric(5,2) [not null, default: 0]
  internal_coordination_score numeric(5,2) [not null, default: 0]
  media_handling_score numeric(5,2) [not null, default: 0]
  official_statement_score numeric(5,2) [not null, default: 0]

  overall_score numeric(5,2)
  details jsonb

  indexes {
    simulation_run_id
    calculated_at
    overall_score
  }

  Note: 'Score agrégé de performance communication'
}

Table communication_events_log {
  id bigserial [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  event_type varchar(100) [not null]
  source_type varchar(100)
  source_id uuid

  title varchar(200)
  description text

  occurred_at timestamptz [not null, default: `now()`]
  actor_user_id uuid
  metadata jsonb

  indexes {
    simulation_run_id
    event_type
    occurred_at
    actor_user_id
  }

  Note: 'Journal transversal de tous les événements de communication'
}

// Ressources & logistique


Enum run_status {
  pending
  ready
  running
  paused
  completed
  cancelled
  archived
}

Enum team_status {
  available
  assigned
  standby
  overloaded
  unavailable
  off_duty
}

Enum member_status {
  available
  assigned
  resting
  injured
  unavailable
  off_shift
}

Enum skill_level {
  novice
  intermediate
  advanced
  expert
  certified
}

Enum fatigue_level {
  fresh
  normal
  tired
  very_tired
  exhausted
}

Enum assignment_status {
  planned
  active
  paused
  completed
  cancelled
  failed
}

Enum asset_category {
  vehicle
  equipment
  consumable
  medical
  it_asset
  communication
  power
  ppe
  facility
  tool
  stock
  custom
}

Enum asset_type {
  individual
  batch
  tracked_unit
  stock_item
}

Enum asset_status {
  operational
  reserved
  deployed
  degraded
  damaged
  critical
  out_of_service
  consumed
  lost
}

Enum maintenance_status {
  up_to_date
  due_soon
  overdue
  blocked
}

Enum degradation_event_type {
  wear
  incident
  overload
  environmental
  misuse
  breakdown
  expiration
  custom
}

Enum stock_movement_type {
  inbound
  outbound
  transfer
  adjustment
  consumption
  loss
  expiry
  replenishment
}

Enum procedure_category {
  bcp
  drp
  evacuation
  communication
  medical
  cyber
  logistics
  hr
  legal
  custom
}

Enum procedure_status {
  draft
  ready
  active
  suspended
  completed
  archived
}

Enum checklist_item_status {
  pending
  in_progress
  done
  skipped
  blocked
  failed
}

Enum budget_status {
  forecast
  active
  frozen
  closed
}

Enum budget_entry_type {
  allocation
  commitment
  expense
  refund
  reserve
  transfer
  penalty
  custom
}

Enum budget_entry_status {
  planned
  approved
  committed
  spent
  cancelled
  rejected
}

Enum cost_category {
  staffing
  transport
  equipment
  fuel
  food
  medical
  it
  facility
  communication
  subcontractor
  emergency_support
  legal
  pr
  miscellaneous
}

Table simulation_runs {
  id uuid [pk, not null]
  scenario_id uuid [not null]
  name varchar(200) [not null]
  code varchar(100) [not null, unique]

  status run_status [not null, default: 'pending']
  started_at timestamptz
  ended_at timestamptz

  created_by uuid
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_id
    status
  }

  Note: 'Référence vers une session de simulation'
}

Table operational_teams {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100) [not null]
  name varchar(150) [not null]
  description text

  team_type varchar(100)
  status team_status [not null, default: 'available']

  capacity_min int
  capacity_max int
  current_load_percent numeric(5,2) [not null, default: 0]

  location_label varchar(150)
  metadata jsonb

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    (simulation_run_id, code) [unique]
    status
    team_type
  }

  Note: '''
  Equipes opérationnelles :
  secours, communication, logistique, IT, médical, sécurité, etc.
  '''
}

Table team_members {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]
  team_id uuid [ref: > operational_teams.id]

  user_id uuid
  actor_code varchar(100)

  employee_code varchar(100)
  first_name varchar(100)
  last_name varchar(100)
  display_name varchar(150)

  role_label varchar(100)
  status member_status [not null, default: 'available']
  fatigue_level fatigue_level [not null, default: 'normal']

  fatigue_score numeric(5,2) [not null, default: 0]
  stress_score numeric(5,2) [not null, default: 0]
  morale_score numeric(5,2) [not null, default: 100]

  availability_percent numeric(5,2) [not null, default: 100]
  shift_start_at timestamptz
  shift_end_at timestamptz
  last_rest_at timestamptz

  medical_restrictions text
  notes text
  metadata jsonb

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    team_id
    user_id
    status
    fatigue_level
    availability_percent
  }

  Note: '''
  Membres humains ou simulés affectables à une équipe.
  fatigue_score/stress_score/morale_score permettent un pilotage fin.
  '''
}

Table skill_catalog {
  id uuid [pk, not null]
  code varchar(100) [not null, unique]
  name varchar(150) [not null]
  category varchar(100)
  description text

  is_certifiable boolean [not null, default: false]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Note: '''
  Exemples :
  first_aid, fire_response, crisis_comms, forensics, evacuation_lead, vehicle_operation
  '''
}

Table member_skills {
  id uuid [pk, not null]
  member_id uuid [not null, ref: > team_members.id]
  skill_id uuid [not null, ref: > skill_catalog.id]

  level skill_level [not null, default: 'novice']
  certified boolean [not null, default: false]
  certification_expires_at timestamptz

  last_verified_at timestamptz
  notes text

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    member_id
    skill_id
    (member_id, skill_id) [unique]
    level
    certified
  }

  Note: 'Compétences et habilitations d’un membre'
}

Table team_assignments {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]
  team_id uuid [ref: > operational_teams.id]
  member_id uuid [ref: > team_members.id]

  code varchar(100)
  title varchar(200) [not null]
  description text

  assignment_status assignment_status [not null, default: 'planned']
  priority int [not null, default: 3]

  assigned_at timestamptz [not null, default: `now()`]
  started_at timestamptz
  completed_at timestamptz

  expected_duration_minutes int
  actual_duration_minutes int

  target_zone_label varchar(150)
  target_location varchar(255)

  fatigue_impact numeric(6,2) [not null, default: 0]
  risk_impact numeric(6,2) [not null, default: 0]
  notes text
  metadata jsonb

  created_by uuid
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    team_id
    member_id
    assignment_status
    assigned_at
  }

  Note: 'Mission ou tâche confiée à une équipe ou un membre'
}

Table fatigue_events {
  id bigserial [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]
  member_id uuid [not null, ref: > team_members.id]
  assignment_id uuid [ref: > team_assignments.id]

  event_type varchar(100) [not null]
  fatigue_delta numeric(6,2) [not null, default: 0]
  stress_delta numeric(6,2) [not null, default: 0]
  morale_delta numeric(6,2) [not null, default: 0]

  recorded_at timestamptz [not null, default: `now()`]
  reason text
  metadata jsonb

  indexes {
    simulation_run_id
    member_id
    assignment_id
    recorded_at
  }

  Note: 'Historique d’évolution fatigue/stress/moral'
}

Table assets {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100) [not null]
  name varchar(150) [not null]
  description text

  asset_category asset_category [not null]
  asset_type asset_type [not null, default: 'individual']
  asset_status asset_status [not null, default: 'operational']
  maintenance_status maintenance_status [not null, default: 'up_to_date']

  serial_number varchar(150)
  batch_number varchar(150)
  manufacturer varchar(150)
  model varchar(150)

  quantity_total numeric(12,2) [not null, default: 1]
  quantity_available numeric(12,2) [not null, default: 1]
  unit varchar(50)

  health_percent numeric(5,2) [not null, default: 100]
  wear_percent numeric(5,2) [not null, default: 0]
  reliability_score numeric(5,2) [not null, default: 100]

  location_label varchar(150)
  assigned_team_id uuid [ref: > operational_teams.id]
  assigned_member_id uuid [ref: > team_members.id]

  purchase_cost numeric(14,2)
  replacement_cost numeric(14,2)

  acquired_at timestamptz
  expires_at timestamptz
  next_maintenance_at timestamptz

  metadata jsonb
  notes text

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    (simulation_run_id, code) [unique]
    asset_category
    asset_type
    asset_status
    maintenance_status
    assigned_team_id
    assigned_member_id
    expires_at
  }

  Note: '''
  Véhicules, radios, groupes électrogènes, EPI, serveurs, médicaments, carburant, etc.
  '''
}

Table asset_degradation_events {
  id bigserial [pk, not null]
  asset_id uuid [not null, ref: > assets.id]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  degradation_event_type degradation_event_type [not null]
  recorded_at timestamptz [not null, default: `now()`]

  wear_delta numeric(6,2) [not null, default: 0]
  health_delta numeric(6,2) [not null, default: 0]
  reliability_delta numeric(6,2) [not null, default: 0]

  quantity_delta numeric(12,2)
  reason text
  related_assignment_id uuid [ref: > team_assignments.id]
  metadata jsonb

  indexes {
    asset_id
    simulation_run_id
    degradation_event_type
    recorded_at
  }

  Note: 'Usure, panne, casse, perte ou péremption du matériel'
}

Table stock_movements {
  id uuid [pk, not null]
  asset_id uuid [not null, ref: > assets.id]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  stock_movement_type stock_movement_type [not null]
  quantity numeric(12,2) [not null]
  unit varchar(50)

  from_location varchar(150)
  to_location varchar(150)

  moved_at timestamptz [not null, default: `now()`]
  performed_by uuid
  related_assignment_id uuid [ref: > team_assignments.id]

  reason text
  metadata jsonb

  indexes {
    asset_id
    simulation_run_id
    stock_movement_type
    moved_at
  }

  Note: 'Entrées, sorties, transferts, consommation, pertes'
}

Table asset_allocations {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]
  asset_id uuid [not null, ref: > assets.id]

  allocated_team_id uuid [ref: > operational_teams.id]
  allocated_member_id uuid [ref: > team_members.id]

  allocated_quantity numeric(12,2) [not null, default: 1]
  allocated_at timestamptz [not null, default: `now()`]
  released_at timestamptz

  status assignment_status [not null, default: 'active']
  purpose text
  notes text

  indexes {
    simulation_run_id
    asset_id
    allocated_team_id
    allocated_member_id
    status
    allocated_at
  }

  Note: 'Affectation d’une ressource matérielle'
}

Table continuity_plans {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100) [not null]
  name varchar(200) [not null]
  description text

  procedure_category procedure_category [not null, default: 'bcp']
  procedure_status procedure_status [not null, default: 'ready']

  version varchar(50)
  objective_label varchar(200)
  activation_criteria text
  owner_role_label varchar(100)

  activated_at timestamptz
  completed_at timestamptz

  metadata jsonb
  notes text

  created_by uuid
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    (simulation_run_id, code) [unique]
    procedure_category
    procedure_status
  }

  Note: 'Procédures PCA/PRA ou plans d’urgence activables'
}

Table continuity_plan_steps {
  id uuid [pk, not null]
  plan_id uuid [not null, ref: > continuity_plans.id]

  code varchar(100) [not null]
  title varchar(200) [not null]
  description text

  display_order int [not null, default: 1]
  is_mandatory boolean [not null, default: true]
  checklist_item_status checklist_item_status [not null, default: 'pending']

  assigned_team_id uuid [ref: > operational_teams.id]
  assigned_member_id uuid [ref: > team_members.id]

  due_after_activation_minutes int
  completed_at timestamptz
  validated_by uuid

  evidence_text text
  metadata jsonb

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    plan_id
    (plan_id, code) [unique]
    display_order
    checklist_item_status
    assigned_team_id
    assigned_member_id
  }

  Note: 'Checklist d’exécution de procédure'
}

Table continuity_step_dependencies {
  id uuid [pk, not null]
  step_id uuid [not null, ref: > continuity_plan_steps.id]
  depends_on_step_id uuid [not null, ref: > continuity_plan_steps.id]

  created_at timestamptz [not null, default: `now()`]

  indexes {
    step_id
    depends_on_step_id
    (step_id, depends_on_step_id) [unique]
  }

  Note: 'Dépendances entre étapes du PCA/PRA'
}

Table continuity_step_logs {
  id bigserial [pk, not null]
  step_id uuid [not null, ref: > continuity_plan_steps.id]

  logged_at timestamptz [not null, default: `now()`]
  actor_user_id uuid

  old_status checklist_item_status
  new_status checklist_item_status [not null]
  comment text
  metadata jsonb

  indexes {
    step_id
    logged_at
    new_status
  }

  Note: 'Traçabilité de l’avancement de la checklist'
}

Table crisis_budgets {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100) [not null]
  name varchar(150) [not null]
  description text

  currency_code varchar(10) [not null, default: 'EUR']
  budget_status budget_status [not null, default: 'active']

  initial_amount numeric(14,2) [not null, default: 0]
  reserved_amount numeric(14,2) [not null, default: 0]
  committed_amount numeric(14,2) [not null, default: 0]
  spent_amount numeric(14,2) [not null, default: 0]
  remaining_amount numeric(14,2) [not null, default: 0]

  warning_threshold numeric(14,2)
  critical_threshold numeric(14,2)

  activated_at timestamptz
  closed_at timestamptz

  metadata jsonb
  notes text

  created_by uuid
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    (simulation_run_id, code) [unique]
    budget_status
  }

  Note: 'Budget global ou sous-budget de crise simulé'
}

Table budget_entries {
  id uuid [pk, not null]
  budget_id uuid [not null, ref: > crisis_budgets.id]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100)
  label varchar(200) [not null]
  description text

  budget_entry_type budget_entry_type [not null]
  budget_entry_status budget_entry_status [not null, default: 'planned']
  cost_category cost_category [not null, default: 'miscellaneous']

  amount numeric(14,2) [not null]
  currency_code varchar(10) [not null, default: 'EUR']

  committed_at timestamptz
  spent_at timestamptz

  requested_by uuid
  approved_by uuid

  related_team_id uuid [ref: > operational_teams.id]
  related_member_id uuid [ref: > team_members.id]
  related_asset_id uuid [ref: > assets.id]
  related_assignment_id uuid [ref: > team_assignments.id]
  related_plan_id uuid [ref: > continuity_plans.id]

  metadata jsonb
  notes text

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    budget_id
    simulation_run_id
    budget_entry_type
    budget_entry_status
    cost_category
    committed_at
    spent_at
  }

  Note: '''
  Lignes budgétaires :
  achat de matériel, carburant, prestataire, hébergement, communication, etc.
  '''
}

Table budget_snapshots {
  id uuid [pk, not null]
  budget_id uuid [not null, ref: > crisis_budgets.id]

  snapshot_time timestamptz [not null, default: `now()`]
  reserved_amount numeric(14,2) [not null, default: 0]
  committed_amount numeric(14,2) [not null, default: 0]
  spent_amount numeric(14,2) [not null, default: 0]
  remaining_amount numeric(14,2) [not null, default: 0]

  details jsonb

  indexes {
    budget_id
    snapshot_time
  }

  Note: 'Historisation de l’état budgétaire'
}

Table logistics_events_log {
  id bigserial [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  event_type varchar(100) [not null]
  source_type varchar(100)
  source_id uuid

  title varchar(200)
  description text

  occurred_at timestamptz [not null, default: `now()`]
  actor_user_id uuid
  metadata jsonb

  indexes {
    simulation_run_id
    event_type
    occurred_at
  }

  Note: 'Journal transversal ressources & logistique'
}

// IA & moteur de jeu 

Project crisis_simulation_game_engine {
  database_type: "PostgreSQL"
  Note: '''
  Moteur de jeu et IA pour simulation de crise.
  Portée :
  - mode scripté (arbre de décision)
  - moteur IA (LLM orchestrateur)
  - NPC dynamiques
  - génération d'événements
  - moteur de conséquences en cascade
  - état runtime du scénario
  '''
}

Enum engine_mode {
  scripted
  hybrid
  ai_driven
}

Enum engine_status {
  idle
  running
  paused
  stopped
  error
}

Enum event_source {
  scripted
  rule_engine
  ai_generated
  facilitator
  system
}

Enum event_status {
  pending
  triggered
  processed
  cancelled
}

Enum npc_type {
  journalist
  authority
  victim
  employee
  citizen
  attacker
  supplier
  partner
  custom
}

Enum npc_state {
  calm
  concerned
  stressed
  aggressive
  cooperative
  hostile
  panic
}

Enum consequence_type {
  variable_change
  resource_impact
  team_impact
  media_impact
  npc_reaction
  trigger_event
  unlock_path
  lock_path
  score_impact
  custom
}

Enum consequence_scope {
  immediate
  delayed
  cascading
}

Enum ai_decision_type {
  event_generation
  npc_response
  evaluation
  escalation
  adaptation
}

Enum ai_evaluation_type {
  response_quality
  timing
  communication
  coordination
  decision_relevance
}

Enum game_variable_type {
  integer
  float
  boolean
  text
  json
}

Table simulation_runs {
  id uuid [pk, not null]
  scenario_id uuid [not null]

  name varchar(200)
  engine_mode engine_mode [not null, default: 'scripted']
  engine_status engine_status [not null, default: 'idle']

  current_tick int [not null, default: 0]
  current_time timestamptz

  seed bigint
  randomness_factor numeric(5,2) [not null, default: 1.00]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz

  indexes {
    scenario_id
    engine_mode
    engine_status
  }
}

Table game_state_variables {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100) [not null]
  name varchar(150)

  variable_type game_variable_type [not null]
  value_text text
  value_number numeric(14,4)
  value_json jsonb

  last_updated_at timestamptz

  indexes {
    simulation_run_id
    (simulation_run_id, code) [unique]
  }

  Note: '''
  Variables runtime du moteur :
  panic_level, media_pressure, casualties, infra_status...
  '''
}

Table game_events {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100)
  title varchar(200)
  description text

  event_source event_source [not null]
  event_status event_status [not null, default: 'pending']

  triggered_at timestamptz
  processed_at timestamptz

  priority int [not null, default: 3]
  severity int [not null, default: 1]

  related_node_id uuid
  related_choice_id uuid

  metadata jsonb

  indexes {
    simulation_run_id
    event_source
    event_status
    triggered_at
  }

  Note: 'Tous les événements générés (scriptés ou IA)'
}

Table game_event_triggers {
  id uuid [pk, not null]
  event_id uuid [not null, ref: > game_events.id]

  trigger_type varchar(100)
  condition_expression text

  scheduled_offset_seconds int
  probability numeric(5,2)

  created_at timestamptz [not null, default: `now()`]

  indexes {
    event_id
  }

  Note: 'Conditions de déclenchement'
}

Table npcs {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100)
  name varchar(150)

  npc_type npc_type [not null]
  npc_state npc_state [not null, default: 'calm']

  personality_profile jsonb
  behavior_profile jsonb

  trust_level numeric(5,2) [not null, default: 50]
  stress_level numeric(5,2) [not null, default: 0]

  influence_score numeric(5,2) [not null, default: 50]

  created_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    npc_type
    npc_state
  }

  Note: '''
  Journalistes, autorités, victimes...
  Avec personnalité et comportement dynamique
  '''
}

Table npc_interactions {
  id uuid [pk, not null]
  npc_id uuid [not null, ref: > npcs.id]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  interaction_type varchar(100)
  input_text text
  response_text text

  triggered_by_event_id uuid [ref: > game_events.id]
  triggered_by_user uuid

  created_at timestamptz [not null, default: `now()`]

  indexes {
    npc_id
    simulation_run_id
    created_at
  }

  Note: 'Historique des interactions avec les NPC'
}

Table consequences {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  source_event_id uuid [ref: > game_events.id]
  source_choice_id uuid

  consequence_type consequence_type [not null]
  consequence_scope consequence_scope [not null]

  target_variable_code varchar(100)
  target_npc_id uuid [ref: > npcs.id]

  value_delta numeric(14,4)
  value_json jsonb

  delay_seconds int [not null, default: 0]
  probability numeric(5,2) [not null, default: 1.00]

  created_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    source_event_id
    consequence_type
    consequence_scope
  }

  Note: 'Effets générés par une action'
}

Table consequence_executions {
  id uuid [pk, not null]
  consequence_id uuid [not null, ref: > consequences.id]

  executed_at timestamptz [not null, default: `now()`]
  execution_status varchar(50)

  resulting_event_id uuid [ref: > game_events.id]

  metadata jsonb

  indexes {
    consequence_id
    executed_at
  }

  Note: 'Traçabilité des conséquences appliquées'
}

Table ai_agents {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  name varchar(150)
  role varchar(100)

  model_name varchar(100)
  temperature numeric(3,2)
  max_tokens int

  system_prompt text
  behavior_prompt text

  is_active boolean [not null, default: true]

  created_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    is_active
  }

  Note: 'Agent IA (LLM) jouant le rôle d’animateur'
}

Table ai_decisions {
  id uuid [pk, not null]
  agent_id uuid [not null, ref: > ai_agents.id]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  ai_decision_type ai_decision_type [not null]

  input_context jsonb
  output_result jsonb

  confidence_score numeric(5,2)
  latency_ms int

  created_at timestamptz [not null, default: `now()`]

  indexes {
    agent_id
    simulation_run_id
    ai_decision_type
    created_at
  }

  Note: 'Décisions prises par l’IA'
}

Table ai_evaluations {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  evaluated_event_id uuid [ref: > game_events.id]
  evaluated_user uuid

  ai_evaluation_type ai_evaluation_type [not null]

  score numeric(5,2)
  feedback_text text
  suggestions text

  created_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    ai_evaluation_type
  }

  Note: 'Évaluation des actions des joueurs par IA'
}

Table engine_rules {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100)
  name varchar(150)

  condition_expression text
  action_definition jsonb

  priority int [not null, default: 100]
  is_active boolean [not null, default: true]

  created_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    is_active
    priority
  }

  Note: 'Règles déterministes du moteur'
}

Table rule_executions {
  id uuid [pk, not null]
  rule_id uuid [not null, ref: > engine_rules.id]

  executed_at timestamptz [not null, default: `now()`]
  result_status varchar(50)

  generated_event_id uuid [ref: > game_events.id]

  metadata jsonb

  indexes {
    rule_id
    executed_at
  }

  Note: 'Exécution des règles moteur'
}

Table cascading_chains {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  root_event_id uuid [not null, ref: > game_events.id]

  description text
  depth int [not null, default: 0]

  created_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    root_event_id
  }

  Note: 'Chaînes d’effets en cascade'
}

Table cascading_links {
  id uuid [pk, not null]
  chain_id uuid [not null, ref: > cascading_chains.id]

  parent_event_id uuid [not null, ref: > game_events.id]
  child_event_id uuid [not null, ref: > game_events.id]

  delay_seconds int
  probability numeric(5,2)

  created_at timestamptz [not null, default: `now()`]

  indexes {
    chain_id
    parent_event_id
    child_event_id
  }

  Note: 'Relations entre événements en cascade'
}

// Analytics et RETEX

Project crisis_simulation_analytics_retex {
  database_type: "PostgreSQL"
  Note: '''
  Module Analytics & Retour d'Expérience.
  Portée :
  - replay complet de la session
  - timeline annotée
  - scoring détaillé des décisions
  - génération de rapport exportable
  - comparaison multi-sessions
  '''
}

Enum run_status {
  pending
  ready
  running
  paused
  completed
  cancelled
  archived
}

Enum replay_event_type {
  scenario_event
  inject
  decision
  action
  communication
  alert
  resource_change
  team_change
  npc_interaction
  procedure_step
  score_event
  annotation
  system
}

Enum replay_visibility {
  facilitator_only
  evaluators_only
  internal_team
  all
}

Enum annotation_type {
  note
  observation
  highlight
  issue
  best_practice
  mistake
  recommendation
  evaluator_comment
  ai_comment
}

Enum score_scope {
  global
  team
  user
  decision
  role
  phase
}

Enum score_metric_type {
  speed
  relevance
  communication
  coordination
  prioritization
  resource_management
  procedure_compliance
  adaptability
  leadership
  overall
}

Enum score_grade {
  very_poor
  poor
  average
  good
  excellent
}

Enum report_status {
  draft
  generating
  ready
  failed
  archived
}

Enum report_type {
  summary
  detailed
  executive
  pedagogical
  compliance
  comparison
  custom
}

Enum export_format {
  pdf
  docx
  html
  json
}

Enum comparison_scope {
  run_to_run
  team_to_team
  user_to_user
  cohort
  scenario
  organization
}

Enum trend_direction {
  improving
  stable
  declining
  volatile
}

Table simulation_runs {
  id uuid [pk, not null]
  scenario_id uuid [not null]
  organization_id uuid
  name varchar(200) [not null]
  code varchar(100) [not null, unique]

  status run_status [not null, default: 'pending']
  started_at timestamptz
  ended_at timestamptz

  difficulty_code varchar(50)
  duration_seconds int
  created_by uuid

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    scenario_id
    organization_id
    status
    started_at
    ended_at
  }

  Note: 'Session de simulation terminée ou en cours d’analyse'
}

Table run_participants {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  user_id uuid
  actor_code varchar(100)
  display_name varchar(150)
  role_label varchar(100)
  team_label varchar(100)

  joined_at timestamptz
  left_at timestamptz

  created_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    user_id
    role_label
    team_label
  }

  Note: 'Participants d’une session, même si non rattachés à un user interne'
}

Table replay_timelines {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100) [not null]
  name varchar(150) [not null]
  description text

  is_master boolean [not null, default: true]
  base_started_at timestamptz
  base_ended_at timestamptz

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    (simulation_run_id, code) [unique]
    is_master
  }

  Note: 'Timeline principale ou timelines spécialisées pour replay'
}

Table replay_events {
  id uuid [pk, not null]
  timeline_id uuid [not null, ref: > replay_timelines.id]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100)
  title varchar(200) [not null]
  description text

  replay_event_type replay_event_type [not null]
  replay_visibility replay_visibility [not null, default: 'all']

  occurred_at timestamptz [not null]
  relative_offset_seconds int
  sequence_order int [not null, default: 1]

  severity_level int [not null, default: 1]
  importance_score numeric(5,2) [not null, default: 0]

  source_type varchar(100)
  source_id uuid

  related_decision_id uuid
  related_participant_id uuid [ref: > run_participants.id]

  metadata jsonb

  created_at timestamptz [not null, default: `now()`]

  indexes {
    timeline_id
    simulation_run_id
    replay_event_type
    occurred_at
    sequence_order
    severity_level
  }

  Note: 'Événements historisés pour relecture complète'
}

Table replay_annotations {
  id uuid [pk, not null]
  replay_event_id uuid [not null, ref: > replay_events.id]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  annotation_type annotation_type [not null]
  title varchar(200)
  content text [not null]

  author_user_id uuid
  author_type varchar(50) [not null, default: 'human']
  is_pinned boolean [not null, default: false]

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    replay_event_id
    simulation_run_id
    annotation_type
    is_pinned
    created_at
  }

  Note: 'Annotations de débrief sur un événement précis'
}

Table replay_bookmarks {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]
  replay_event_id uuid [not null, ref: > replay_events.id]

  label varchar(150) [not null]
  color varchar(30)
  created_by uuid
  created_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    replay_event_id
    created_by
  }

  Note: 'Marqueurs importants pour le replay'
}

Table scoring_frameworks {
  id uuid [pk, not null]
  scenario_id uuid
  code varchar(100) [not null, unique]
  name varchar(150) [not null]
  description text

  version varchar(50)
  is_default boolean [not null, default: false]
  config jsonb

  created_by uuid
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Note: 'Référentiel d’évaluation réutilisable'
}

Table scoring_criteria {
  id uuid [pk, not null]
  framework_id uuid [not null, ref: > scoring_frameworks.id]

  code varchar(100) [not null]
  name varchar(150) [not null]
  description text

  score_metric_type score_metric_type [not null]
  weight numeric(6,2) [not null, default: 1.00]

  min_score numeric(6,2) [not null, default: 0]
  max_score numeric(6,2) [not null, default: 100]

  expected_response_seconds int
  rubric jsonb

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    framework_id
    (framework_id, code) [unique]
    score_metric_type
  }

  Note: '''
  Critères :
  rapidité, pertinence, communication, coordination, etc.
  '''
}

Table run_scorecards {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]
  framework_id uuid [ref: > scoring_frameworks.id]

  score_scope score_scope [not null, default: 'global']
  scope_ref_id uuid

  global_score numeric(6,2) [not null, default: 0]
  percentile_rank numeric(6,2)
  score_grade score_grade

  calculated_at timestamptz [not null, default: `now()`]
  calculated_by uuid
  calculation_method varchar(100)

  summary jsonb

  indexes {
    simulation_run_id
    framework_id
    score_scope
    scope_ref_id
    calculated_at
  }

  Note: '''
  Scorecard globale, par équipe, par participant, par rôle ou par phase.
  scope_ref_id est polymorphe selon score_scope.
  '''
}

Table decision_scores {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  decision_ref_id uuid [not null]
  participant_id uuid [ref: > run_participants.id]

  score_speed numeric(6,2) [not null, default: 0]
  score_relevance numeric(6,2) [not null, default: 0]
  score_communication numeric(6,2) [not null, default: 0]
  score_coordination numeric(6,2) [not null, default: 0]
  score_overall numeric(6,2) [not null, default: 0]

  expected_response_seconds int
  actual_response_seconds int
  delay_penalty numeric(6,2) [not null, default: 0]

  score_grade score_grade
  rationale text
  evaluator_user_id uuid
  evaluator_type varchar(50) [not null, default: 'human']

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    decision_ref_id
    participant_id
    score_overall
    created_at
  }

  Note: 'Notation détaillée d’une décision'
}

Table score_breakdowns {
  id uuid [pk, not null]
  scorecard_id uuid [not null, ref: > run_scorecards.id]
  criterion_id uuid [not null, ref: > scoring_criteria.id]

  raw_score numeric(6,2) [not null, default: 0]
  weighted_score numeric(6,2) [not null, default: 0]
  score_grade score_grade

  comment text
  evidence jsonb

  created_at timestamptz [not null, default: `now()`]

  indexes {
    scorecard_id
    criterion_id
    (scorecard_id, criterion_id) [unique]
  }

  Note: 'Détail par critère d’un scorecard'
}

Table performance_indicators {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100) [not null]
  name varchar(150) [not null]
  description text

  value numeric(12,2) [not null, default: 0]
  unit varchar(50)
  trend_direction trend_direction
  benchmark_value numeric(12,2)

  category varchar(100)
  metadata jsonb

  measured_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    (simulation_run_id, code) [unique]
    category
    measured_at
  }

  Note: '''
  KPI post-exercice :
  temps moyen de réponse, nombre d’erreurs, taux de procédures respectées, etc.
  '''
}

Table generated_reports {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  report_type report_type [not null]
  report_status report_status [not null, default: 'draft']
  export_format export_format [not null, default: 'pdf']

  title varchar(200) [not null]
  executive_summary text
  report_data jsonb
  template_code varchar(100)

  file_url text
  file_name varchar(255)

  generated_by uuid
  generation_started_at timestamptz
  generated_at timestamptz

  error_message text

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    report_type
    report_status
    export_format
    generated_at
  }

  Note: 'Rapport exportable, notamment PDF'
}

Table report_sections {
  id uuid [pk, not null]
  report_id uuid [not null, ref: > generated_reports.id]

  code varchar(100) [not null]
  title varchar(200) [not null]
  display_order int [not null, default: 1]

  content_text text
  content_json jsonb

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    report_id
    (report_id, code) [unique]
    display_order
  }

  Note: 'Sections du rapport : résumé, scoring, timeline, recommandations, etc.'
}

Table report_exports {
  id uuid [pk, not null]
  report_id uuid [not null, ref: > generated_reports.id]

  export_format export_format [not null]
  file_url text
  file_name varchar(255)
  checksum varchar(255)

  exported_at timestamptz [not null, default: `now()`]
  exported_by uuid

  indexes {
    report_id
    export_format
    exported_at
  }

  Note: 'Historique des exports d’un même rapport'
}

Table retex_summaries {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  title varchar(200) [not null]
  summary_text text [not null]

  strengths text
  weaknesses text
  recommendations text
  lessons_learned text

  generated_by_type varchar(50) [not null, default: 'human']
  generated_by uuid
  generated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    generated_at
  }

  Note: 'Synthèse de retour d’expérience'
}

Table retex_action_items {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  title varchar(200) [not null]
  description text
  priority int [not null, default: 3]

  owner_user_id uuid
  target_due_date date

  status varchar(50) [not null, default: 'open']
  completion_percent numeric(5,2) [not null, default: 0]

  source_annotation_id uuid [ref: > replay_annotations.id]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    owner_user_id
    status
    target_due_date
    priority
  }

  Note: 'Actions correctives ou d’amélioration issues du RETEX'
}

Table comparison_sets {
  id uuid [pk, not null]
  code varchar(100) [not null, unique]
  name varchar(150) [not null]
  description text

  comparison_scope comparison_scope [not null]
  created_by uuid

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Note: 'Jeu de comparaison multi-sessions'
}

Table comparison_set_runs {
  id uuid [pk, not null]
  comparison_set_id uuid [not null, ref: > comparison_sets.id]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  label varchar(150)
  sort_order int [not null, default: 1]

  indexes {
    comparison_set_id
    simulation_run_id
    (comparison_set_id, simulation_run_id) [unique]
    sort_order
  }

  Note: 'Runs inclus dans une comparaison'
}

Table comparison_metrics {
  id uuid [pk, not null]
  comparison_set_id uuid [not null, ref: > comparison_sets.id]

  metric_code varchar(100) [not null]
  metric_name varchar(150) [not null]
  description text

  unit varchar(50)
  better_direction varchar(20) [not null, default: 'higher']
  weight numeric(6,2) [not null, default: 1.00]

  created_at timestamptz [not null, default: `now()`]

  indexes {
    comparison_set_id
    (comparison_set_id, metric_code) [unique]
  }

  Note: 'Indicateurs retenus pour comparer plusieurs sessions'
}

Table comparison_results {
  id uuid [pk, not null]
  comparison_set_id uuid [not null, ref: > comparison_sets.id]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]
  metric_id uuid [not null, ref: > comparison_metrics.id]

  metric_value numeric(12,2) [not null]
  rank_position int
  percentile numeric(6,2)
  delta_vs_baseline numeric(12,2)

  calculated_at timestamptz [not null, default: `now()`]
  metadata jsonb

  indexes {
    comparison_set_id
    simulation_run_id
    metric_id
    (comparison_set_id, simulation_run_id, metric_id) [unique]
  }

  Note: 'Résultats de benchmark entre sessions'
}

Table progression_profiles {
  id uuid [pk, not null]
  subject_type varchar(50) [not null]
  subject_id uuid [not null]

  name varchar(150)
  description text

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    subject_type
    subject_id
  }

  Note: '''
  Profil de progression d’un utilisateur, d’une équipe ou d’une cohorte.
  subject_type : user, team, organization, cohort
  '''
}

Table progression_points {
  id uuid [pk, not null]
  progression_profile_id uuid [not null, ref: > progression_profiles.id]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  measured_at timestamptz [not null, default: `now()`]
  overall_score numeric(6,2)
  communication_score numeric(6,2)
  speed_score numeric(6,2)
  coordination_score numeric(6,2)
  relevance_score numeric(6,2)

  notes text
  metadata jsonb

  indexes {
    progression_profile_id
    simulation_run_id
    measured_at
  }

  Note: 'Points de progression dans le temps'
}

Table analytics_events_log {
  id bigserial [pk, not null]
  simulation_run_id uuid [ref: > simulation_runs.id]

  event_type varchar(100) [not null]
  title varchar(200)
  description text

  source_type varchar(100)
  source_id uuid

  occurred_at timestamptz [not null, default: `now()`]
  actor_user_id uuid
  metadata jsonb

  indexes {
    simulation_run_id
    event_type
    occurred_at
  }

  Note: 'Journal technique et analytique du module RETEX'
}


// Main Courante à Valeur Probante

Project crisis_simulation_probative_logbook {
  database_type: "PostgreSQL"
  Note: '''
  Main Courante à Valeur Probante.
  Objectifs :
  - journal append-only
  - horodatage immuable
  - traçabilité des ordres
  - chaînage d’intégrité
  - audit et preuve
  '''
}

Enum probative_log_status {
  open
  sealed
  archived
}

Enum probative_entry_type {
  observation
  event
  decision
  order
  acknowledgement
  action_report
  communication
  incident
  escalation
  status_update
  legal_note
  system_trace
}

Enum probative_channel_type {
  in_person
  phone
  radio
  email
  sms
  chat
  dashboard
  video_call
  siren
  system
  other
}

Enum probative_order_status {
  issued
  received
  acknowledged
  in_progress
  executed
  partially_executed
  refused
  failed
  cancelled
}

Enum probative_signature_type {
  user_signature
  system_signature
  hash_chain
  external_timestamp
}

Enum probative_actor_type {
  user
  npc
  system
  external_party
}

Enum custody_event_type {
  created
  sealed
  exported
  viewed
  verified
  archived
}

Table simulation_runs {
  id uuid [pk, not null]
  scenario_id uuid [not null]
  name varchar(200) [not null]
  code varchar(100) [not null, unique]

  created_at timestamptz [not null, default: `now()`]

  Note: 'Référence minimale vers la session de simulation'
}

Table probative_logbooks {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100) [not null, unique]
  title varchar(200) [not null]
  description text

  status probative_log_status [not null, default: 'open']
  timezone varchar(100) [not null, default: 'Europe/Paris']

  opened_at timestamptz [not null, default: `now()`]
  sealed_at timestamptz
  archived_at timestamptz

  opened_by uuid
  sealed_by uuid
  archived_by uuid

  chain_algorithm varchar(100) [not null, default: 'sha256']
  current_head_hash varchar(255)
  external_anchor_ref text

  metadata jsonb
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id [unique]
    status
    opened_at
    sealed_at
  }

  Note: '''
  Main courante de la session.
  Une seule principale par run, mais extensible si besoin.
  '''
}

Table probative_log_entries {
  id uuid [pk, not null]
  logbook_id uuid [not null, ref: > probative_logbooks.id]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  sequence_number bigint [not null]
  entry_type probative_entry_type [not null]

  event_time timestamptz [not null]
  recorded_at timestamptz [not null, default: `now()`]

  actor_type probative_actor_type [not null]
  actor_user_id uuid
  actor_label varchar(150)

  title varchar(200)
  content text [not null]
  factual_summary text

  source_channel probative_channel_type [not null, default: 'dashboard']
  source_reference varchar(255)

  related_decision_id uuid
  related_event_id uuid
  related_order_id uuid
  related_message_id uuid
  related_task_id uuid

  parent_entry_id uuid [ref: > probative_log_entries.id]

  is_system_generated boolean [not null, default: false]
  integrity_hash varchar(255) [not null]
  previous_hash varchar(255)
  entry_signature varchar(255)
  signature_type probative_signature_type [not null, default: 'hash_chain']

  immutable_locked boolean [not null, default: true]
  metadata jsonb

  created_at timestamptz [not null, default: `now()`]

  indexes {
    logbook_id
    simulation_run_id
    (logbook_id, sequence_number) [unique]
    event_time
    recorded_at
    entry_type
    actor_user_id
    related_order_id
    parent_entry_id
  }

  Note: '''
  Entrées append-only de la main courante.
  Aucune modification autorisée après écriture.
  previous_hash + integrity_hash = chaîne d’intégrité.
  '''
}

Table probative_entry_attachments {
  id uuid [pk, not null]
  entry_id uuid [not null, ref: > probative_log_entries.id]

  file_name varchar(255) [not null]
  mime_type varchar(150)
  file_url text
  checksum varchar(255) [not null]

  description text
  metadata jsonb

  created_at timestamptz [not null, default: `now()`]

  indexes {
    entry_id
    checksum
  }

  Note: 'Pièces jointes probantes : mail, capture, document, audio, etc.'
}

Table probative_orders {
  id uuid [pk, not null]
  logbook_id uuid [not null, ref: > probative_logbooks.id]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100) [not null]
  title varchar(200) [not null]
  description text [not null]

  issued_at timestamptz [not null]
  status probative_order_status [not null, default: 'issued']
  channel probative_channel_type [not null]

  issuer_actor_type probative_actor_type [not null]
  issuer_user_id uuid
  issuer_label varchar(150) [not null]

  target_actor_type probative_actor_type [not null]
  target_user_id uuid
  target_label varchar(150) [not null]

  priority int [not null, default: 3]
  deadline_at timestamptz
  execution_report text

  originating_entry_id uuid [ref: > probative_log_entries.id]
  current_status_entry_id uuid [ref: > probative_log_entries.id]

  integrity_hash varchar(255) [not null]
  metadata jsonb

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    logbook_id
    simulation_run_id
    (simulation_run_id, code) [unique]
    issued_at
    status
    issuer_user_id
    target_user_id
    priority
  }

  Note: '''
  Formalisation des ordres.
  Qui donne l’ordre, à qui, quand, par quel canal.
  '''
}

Table probative_order_status_history {
  id uuid [pk, not null]
  order_id uuid [not null, ref: > probative_orders.id]
  entry_id uuid [ref: > probative_log_entries.id]

  status probative_order_status [not null]
  changed_at timestamptz [not null]
  changed_by_actor_type probative_actor_type [not null]
  changed_by_user_id uuid
  changed_by_label varchar(150)

  comment text
  integrity_hash varchar(255) [not null]
  previous_hash varchar(255)

  created_at timestamptz [not null, default: `now()`]

  indexes {
    order_id
    status
    changed_at
    changed_by_user_id
  }

  Note: 'Historique immuable des changements d’état d’un ordre'
}

Table probative_acknowledgements {
  id uuid [pk, not null]
  order_id uuid [not null, ref: > probative_orders.id]
  entry_id uuid [ref: > probative_log_entries.id]

  acknowledged_at timestamptz [not null]
  acknowledged_by_actor_type probative_actor_type [not null]
  acknowledged_by_user_id uuid
  acknowledged_by_label varchar(150) [not null]

  channel probative_channel_type [not null]
  response_text text

  integrity_hash varchar(255) [not null]
  previous_hash varchar(255)

  created_at timestamptz [not null, default: `now()`]

  indexes {
    order_id
    acknowledged_at
    acknowledged_by_user_id
  }

  Note: 'Accusé de réception explicite d’un ordre'
}

Table probative_actor_registry {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  actor_type probative_actor_type [not null]
  user_id uuid
  actor_code varchar(100)
  display_name varchar(150) [not null]
  role_label varchar(100)
  external_org varchar(150)

  created_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    actor_type
    user_id
    actor_code
  }

  Note: 'Référentiel des acteurs pouvant apparaître dans la main courante'
}

Table probative_chain_verifications {
  id uuid [pk, not null]
  logbook_id uuid [not null, ref: > probative_logbooks.id]

  verified_at timestamptz [not null, default: `now()`]
  verified_by uuid

  first_sequence_number bigint
  last_sequence_number bigint
  expected_head_hash varchar(255)
  computed_head_hash varchar(255)

  is_valid boolean [not null]
  verification_report text
  metadata jsonb

  indexes {
    logbook_id
    verified_at
    is_valid
  }

  Note: 'Vérification d’intégrité de la chaîne de la main courante'
}

Table probative_custody_events {
  id uuid [pk, not null]
  logbook_id uuid [not null, ref: > probative_logbooks.id]

  custody_event_type custody_event_type [not null]
  occurred_at timestamptz [not null, default: `now()`]
  actor_user_id uuid

  details text
  export_ref text
  checksum varchar(255)
  metadata jsonb

  indexes {
    logbook_id
    custody_event_type
    occurred_at
    actor_user_id
  }

  Note: '''
  Chaîne de conservation :
  consultation, scellement, export, archivage, vérification.
  '''
}

Table probative_export_packages {
  id uuid [pk, not null]
  logbook_id uuid [not null, ref: > probative_logbooks.id]

  package_type varchar(50) [not null, default: 'pdf_bundle']
  file_name varchar(255) [not null]
  file_url text
  package_checksum varchar(255) [not null]

  exported_at timestamptz [not null, default: `now()`]
  exported_by uuid

  includes_chain_report boolean [not null, default: true]
  includes_attachments boolean [not null, default: true]
  includes_order_trace boolean [not null, default: true]

  metadata jsonb

  indexes {
    logbook_id
    exported_at
    package_checksum
  }

  Note: 'Bundle exportable à valeur de preuve / audit / débrief'
}

Project crisis_simulation_extended_modules {
  database_type: "PostgreSQL"
  Note: '''
  Modules complémentaires :
  - simulation de l'écosystème externe / parties prenantes
  - observateur / évaluateur
  - stress test et modes dégradés
  - RETEX automatisé avancé / KPI
  '''
}

Enum stakeholder_type {
  authority
  insurer
  legal_counsel
  shareholder
  union
  regulator
  supplier
  partner
  emergency_service
  media
  ngo
  customer
  custom
}

Enum stakeholder_status {
  active
  standby
  unavailable
  escalated
  hostile
  cooperative
}

Enum authority_type {
  prefecture
  police
  gendarmerie
  ars
  cnil
  fire_department
  municipality
  prosecutor
  custom
}

Enum stakeholder_interaction_type {
  incoming_request
  outgoing_request
  notification
  escalation
  report_submission
  compliance_request
  meeting
  phone_call
  email
  legal_notice
  custom
}

Enum stakeholder_interaction_status {
  pending
  sent
  acknowledged
  answered
  overdue
  ignored
  closed
}

Enum observer_session_status {
  active
  paused
  ended
}

Enum observation_flag_type {
  good_reflex
  communication_error
  safety_omission
  leadership
  prioritization_issue
  legal_risk
  coordination_issue
  procedure_compliance
  notable_action
  custom
}

Enum observation_severity {
  info
  low
  medium
  high
  critical
}

Enum monitored_screen_type {
  dashboard
  communications
  map
  decision_panel
  logistics
  custom
}

Enum degradation_type {
  mail_server_down
  chat_down
  voice_down
  dashboard_latency
  network_partition
  backup_channel_forced
  key_decider_unavailable
  authority_unreachable
  custom
}

Enum degradation_status {
  scheduled
  active
  resolved
  cancelled
}

Enum fallback_mode_type {
  backup_chat
  emergency_radio
  sms_only
  secure_hotline
  paper_mode
  delegated_authority
  alternate_workflow
  custom
}

Enum delegation_status {
  planned
  active
  expired
  cancelled
}

Enum kpi_type {
  mttr
  media_accuracy
  legal_compliance
  first_statement_delay
  decision_latency
  escalation_delay
  stakeholder_response_quality
  custom
}

Table simulation_runs {
  id uuid [pk, not null]
  scenario_id uuid [not null]
  name varchar(200) [not null]
  code varchar(100) [not null, unique]

  created_at timestamptz [not null, default: `now()`]

  Note: 'Référence minimale vers une session'
}

Table external_stakeholders {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100) [not null]
  name varchar(200) [not null]
  stakeholder_type stakeholder_type [not null]
  authority_type authority_type

  status stakeholder_status [not null, default: 'active']
  organization_name varchar(200)
  contact_role varchar(150)

  formality_level int [not null, default: 3]
  pressure_level int [not null, default: 1]
  trust_level numeric(5,2) [not null, default: 50]

  ai_played boolean [not null, default: true]
  ai_persona_profile jsonb
  protocol_requirements jsonb
  legal_constraints jsonb

  metadata jsonb
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    (simulation_run_id, code) [unique]
    stakeholder_type
    authority_type
    status
  }

  Note: '''
  Préfecture, Gendarmerie, ARS, CNIL, assureur, avocat, actionnaires, syndicats...
  '''
}

Table stakeholder_interactions {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]
  stakeholder_id uuid [not null, ref: > external_stakeholders.id]

  interaction_type stakeholder_interaction_type [not null]
  status stakeholder_interaction_status [not null, default: 'pending']

  direction varchar(10) [not null, default: 'inbound']
  subject varchar(255)
  content_text text [not null]

  initiated_at timestamptz [not null, default: `now()`]
  due_at timestamptz
  acknowledged_at timestamptz
  answered_at timestamptz
  closed_at timestamptz

  initiated_by_user_id uuid
  handled_by_user_id uuid

  related_message_id uuid
  related_alert_id uuid
  related_statement_id uuid
  related_probative_entry_id uuid

  response_quality_score numeric(5,2)
  formality_score numeric(5,2)
  legal_accuracy_score numeric(5,2)

  metadata jsonb

  indexes {
    simulation_run_id
    stakeholder_id
    interaction_type
    status
    initiated_at
    due_at
  }

  Note: 'Échanges simulés avec les parties prenantes'
}

Table stakeholder_requirements {
  id uuid [pk, not null]
  stakeholder_id uuid [not null, ref: > external_stakeholders.id]

  code varchar(100) [not null]
  title varchar(200) [not null]
  description text

  required_response boolean [not null, default: true]
  expected_delay_minutes int
  required_channel varchar(100)
  required_format varchar(100)

  validation_rules jsonb
  created_at timestamptz [not null, default: `now()`]

  indexes {
    stakeholder_id
    (stakeholder_id, code) [unique]
  }

  Note: 'Contraintes de forme : ton administratif, pièces, délai, canal'
}

Table stakeholder_escalations {
  id uuid [pk, not null]
  interaction_id uuid [not null, ref: > stakeholder_interactions.id]

  escalated_at timestamptz [not null, default: `now()`]
  escalation_level int [not null, default: 1]
  reason text [not null]

  resulting_impact jsonb
  metadata jsonb

  indexes {
    interaction_id
    escalated_at
    escalation_level
  }

  Note: 'Escalade si absence de réponse, erreur formelle, retard, etc.'
}

Table observer_sessions {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  observer_user_id uuid [not null]
  observer_session_status observer_session_status [not null, default: 'active']

  started_at timestamptz [not null, default: `now()`]
  ended_at timestamptz

  permissions jsonb
  metadata jsonb

  indexes {
    simulation_run_id
    observer_user_id
    observer_session_status
    started_at
  }

  Note: 'Session d’observation d’un formateur'
}

Table observer_screen_streams {
  id uuid [pk, not null]
  observer_session_id uuid [not null, ref: > observer_sessions.id]

  participant_user_id uuid [not null]
  monitored_screen_type monitored_screen_type [not null]
  stream_label varchar(150)

  source_ref varchar(255)
  is_live boolean [not null, default: true]
  started_at timestamptz [not null, default: `now()`]
  ended_at timestamptz

  metadata jsonb

  indexes {
    observer_session_id
    participant_user_id
    monitored_screen_type
    is_live
  }

  Note: 'Vue miroir des écrans ou espaces de travail des participants'
}

Table observation_flags {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]
  observer_user_id uuid [not null]

  observation_flag_type observation_flag_type [not null]
  observation_severity severity [not null, default: 'info']
  label varchar(150) [not null]
  comment text

  flagged_at timestamptz [not null, default: `now()`]

  target_user_id uuid
  target_team_label varchar(100)
  related_decision_id uuid
  related_event_id uuid
  related_message_id uuid
  related_probative_entry_id uuid

  category varchar(100)
  metadata jsonb

  indexes {
    simulation_run_id
    observer_user_id
    observation_flag_type
    flagged_at
    target_user_id
  }

  Note: 'Flags posés à la volée pendant l’exercice'
}

Table observation_notes {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]
  observer_user_id uuid [not null]

  title varchar(200)
  note_text text [not null]
  created_at timestamptz [not null, default: `now()`]

  related_flag_id uuid [ref: > observation_flags.id]
  related_event_id uuid
  related_decision_id uuid

  metadata jsonb

  indexes {
    simulation_run_id
    observer_user_id
    created_at
    related_flag_id
  }

  Note: 'Notes longues d’évaluation'
}

Table system_degradations {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100) [not null]
  title varchar(200) [not null]
  description text

  degradation_type degradation_type [not null]
  degradation_status degradation_status [not null, default: 'scheduled']

  scheduled_start_at timestamptz
  activated_at timestamptz
  resolved_at timestamptz

  impact_scope jsonb
  impact_rules jsonb
  fallback_required boolean [not null, default: false]

  created_by uuid
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    (simulation_run_id, code) [unique]
    degradation_type
    degradation_status
    scheduled_start_at
  }

  Note: 'Pannes simulées et dégradations de service'
}

Table fallback_modes {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]
  degradation_id uuid [ref: > system_degradations.id]

  fallback_mode_type fallback_mode_type [not null]
  code varchar(100) [not null]
  name varchar(150) [not null]
  description text

  activation_conditions jsonb
  instructions_text text
  available_channels jsonb

  activated_at timestamptz
  deactivated_at timestamptz
  active boolean [not null, default: false]

  metadata jsonb

  indexes {
    simulation_run_id
    degradation_id
    (simulation_run_id, code) [unique]
    fallback_mode_type
    active
  }

  Note: 'Modes dégradés proposés ou imposés par l’application'
}

Table decision_maker_availability {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  user_id uuid
  actor_code varchar(100)
  display_name varchar(150) [not null]
  role_label varchar(100)

  available boolean [not null, default: true]
  reachable boolean [not null, default: true]
  unavailable_reason text

  unavailable_from timestamptz
  unavailable_until timestamptz

  metadata jsonb
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    user_id
    actor_code
    available
    reachable
    unavailable_from
  }

  Note: 'Disponibilité des décideurs clés'
}

Table authority_delegations {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100) [not null]
  title varchar(200) [not null]

  principal_user_id uuid
  principal_label varchar(150) [not null]

  delegate_user_id uuid
  delegate_label varchar(150) [not null]

  scope_text text [not null]
  delegation_status delegation_status [not null, default: 'planned']

  effective_from timestamptz [not null]
  effective_until timestamptz

  trigger_reason text
  related_degradation_id uuid [ref: > system_degradations.id]
  related_probative_entry_id uuid

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    (simulation_run_id, code) [unique]
    principal_user_id
    delegate_user_id
    delegation_status
    effective_from
  }

  Note: 'Délégation de pouvoir si décideur indisponible'
}

Table analytical_timelines {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100) [not null]
  name varchar(150) [not null]
  description text

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    (simulation_run_id, code) [unique]
  }

  Note: 'Timeline analytique dédiée au RETEX'
}

Table analytical_timeline_links {
  id uuid [pk, not null]
  analytical_timeline_id uuid [not null, ref: > analytical_timelines.id]

  source_event_type varchar(100) [not null]
  source_event_id uuid [not null]

  reaction_event_type varchar(100)
  reaction_event_id uuid

  linked_by varchar(50) [not null, default: 'system']
  link_reason text
  causality_confidence numeric(5,2)

  delay_seconds int
  created_at timestamptz [not null, default: `now()`]

  indexes {
    analytical_timeline_id
    source_event_type
    source_event_id
    reaction_event_type
    reaction_event_id
  }

  Note: 'Corrélation inject → réaction → conséquence'
}

Table performance_kpis {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100) [not null]
  name varchar(150) [not null]
  kpi_type kpi_type [not null]

  value numeric(12,2) [not null, default: 0]
  unit varchar(50)
  target_value numeric(12,2)

  calculation_method varchar(100)
  calculation_details jsonb

  measured_at timestamptz [not null, default: `now()`]

  indexes {
    simulation_run_id
    (simulation_run_id, code) [unique]
    kpi_type
    measured_at
  }

  Note: 'KPIs de performance avancés'
}

Table legal_compliance_checks {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  code varchar(100) [not null]
  title varchar(200) [not null]
  legal_domain varchar(100) [not null]

  expected_action text
  actual_action text

  compliant boolean
  severity_level int [not null, default: 1]
  compliance_score numeric(5,2)

  evaluated_at timestamptz [not null, default: `now()`]
  evaluator_type varchar(50) [not null, default: 'system']
  evaluator_user_id uuid

  related_event_id uuid
  related_decision_id uuid
  related_statement_id uuid
  related_probative_entry_id uuid

  rationale text
  metadata jsonb

  indexes {
    simulation_run_id
    (simulation_run_id, code) [unique]
    legal_domain
    compliant
    evaluated_at
  }

  Note: '''
  Vérifications RGPD, sécurité environnementale, notification autorité, etc.
  '''
}

Table media_accuracy_assessments {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  statement_id uuid
  assessed_at timestamptz [not null, default: `now()`]

  factual_accuracy_score numeric(5,2) [not null, default: 0]
  clarity_score numeric(5,2) [not null, default: 0]
  completeness_score numeric(5,2) [not null, default: 0]
  consistency_score numeric(5,2) [not null, default: 0]

  misinformation_risk_score numeric(5,2)
  assessed_by_type varchar(50) [not null, default: 'system']
  assessed_by_user_id uuid

  rationale text
  metadata jsonb

  indexes {
    simulation_run_id
    statement_id
    assessed_at
  }

  Note: 'Précision et qualité de l’information transmise aux médias'
}

Table retex_dashboard_exports {
  id uuid [pk, not null]
  simulation_run_id uuid [not null, ref: > simulation_runs.id]

  export_type varchar(50) [not null, default: 'dashboard_pdf']
  title varchar(200) [not null]

  file_url text
  file_name varchar(255)
  checksum varchar(255)

  includes_kpis boolean [not null, default: true]
  includes_timeline boolean [not null, default: true]
  includes_flags boolean [not null, default: true]
  includes_compliance boolean [not null, default: true]

  generated_at timestamptz [not null, default: `now()`]
  generated_by uuid

  metadata jsonb

  indexes {
    simulation_run_id
    generated_at
  }

  Note: 'Exports du RETEX analytique'
}